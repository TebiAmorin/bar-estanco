---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://barestanco.es/images/og-bar-estanco.png'
} = Astro.props;

const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://barestanco.es${ogImage}`;

const siteName = 'Bar Estanco';
const isHome = title.includes('Vinoteca y Tapería');
const fullTitle = isHome
  ? 'Bar Estanco · Vinoteca y Tapería en Gondomar desde 1938'
  : `${title} · ${siteName}`;

// Schema.org LocalBusiness
const schemaData = {
  "@context": "https://schema.org",
  "@type": ["BarOrPub", "WineBar"],
  "name": "Bar Estanco",
  "description": "Café bar, vinoteca y tapería en Gondomar desde 1938. Más de 70 referencias de vino, vermuts, tapas gallegas y conservas premium. Cuatro generaciones de la misma familia. Bar Estanco.",
  "foundingDate": "1938",
  "url": "https://barestanco.es",
  "telephone": "+34986360098",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rúa San Bieito, 1",
    "addressLocality": "Gondomar",
    "addressRegion": "Pontevedra",
    "postalCode": "36380",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.1131,
    "longitude": -8.7586
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Monday",
      "opens": "16:30",
      "closes": "23:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:30",
      "closes": "14:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "16:30",
      "closes": "23:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "15:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "17:00",
      "closes": "23:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Sunday", "PublicHolidays"],
      "opens": "10:00",
      "closes": "15:00"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "97",
    "bestRating": "5"
  },
  "hasMenu": {
    "@type": "Menu",
    "url": "https://barestanco.es/carta"
  },
  "servesCuisine": ["Tapas gallegas", "Vinos", "Vermuts", "Conservas gourmet", "Tapería", "Desayunos"],
  "keywords": "bar estanco, vinoteca gondomar, café bar gondomar, tapería gondomar, vino gondomar, tapas gondomar, bar gondomar, vermut gondomar, desayunos gondomar",
  "priceRange": "€€",
  "image": "https://barestanco.es/images/og-bar-estanco.png",
  "sameAs": ["https://www.instagram.com/estancogondomar/"]
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO Primary -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />

  <!-- Geo & Local SEO -->
  <meta name="geo.region" content="ES-PO" />
  <meta name="geo.placename" content="Gondomar" />
  <meta name="geo.position" content="42.1131;-8.7586" />
  <meta name="ICBM" content="42.1131, -8.7586" />

  <!-- Theme & Mobile -->
  <meta name="theme-color" content="#1a1a1a" />
  <meta name="apple-mobile-web-app-title" content="Bar Estanco" />
  <meta name="application-name" content="Bar Estanco" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- Fuentes: preconnect + carga no-bloqueante -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Cedarville+Cursive&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Cedarville+Cursive&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Cedarville+Cursive&display=swap" /></noscript>

  <!-- View Transitions -->
  <ClientRouter />

  <!-- GSAP & ScrollTrigger -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Skip to content (accesibilidad) -->
  <a href="#main-content" class="skip-to-content">Saltar al contenido</a>

  <Header />

  <main id="main-content" class="flex-1" role="main">
    <slot />
  </main>

  <Footer />

  <!-- Fade-in observer (compatible con View Transitions) -->
  <script>
    function initFadeIn() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.fade-in:not(.visible)').forEach((el) => observer.observe(el));
    }

    // Ejecutar al cargar y tras cada View Transition
    initFadeIn();
    document.addEventListener('astro:after-swap', initFadeIn);

    // Smart Header Dinámico y Global (Compatible con View Transitions)
    let lastScrollY = window.scrollY;
    let isHeaderHidden = false;

    function initSmartHeader() {
      if (typeof gsap === 'undefined') return;
      
      // Resetear estado al entrar en una nueva página
      const html = document.documentElement;
      const initialNavs = document.querySelectorAll('header, .carta-subnav');
      if (initialNavs.length > 0) {
        gsap.set(initialNavs, { y: 0, force3D: true });
      }
      isHeaderHidden = false;
      html.classList.remove('header-hidden');
      lastScrollY = window.scrollY;

      // Si ya hay un listener, no añadimos otro, pero el resto de la función sí se ejecuta para el reset
      if (window.smartHeaderActive) return;
      window.smartHeaderActive = true;

      window.addEventListener('scroll', () => {
        // Seleccionamos el header y el nav de categorías que son los que ahora son fijos
        const navs = document.querySelectorAll('header, .carta-nav-sticky');
        if (navs.length === 0) return;

        const currentScrollY = window.scrollY;
        const delta = currentScrollY - lastScrollY;
        
        if (Math.abs(delta) < 5) return; // Sensibilidad alta

        if (currentScrollY < 100) {
          // Zona superior: Siempre visible
          if (isHeaderHidden) {
            gsap.to(navs, { y: 0, duration: 0.3, ease: 'power2.out', overwrite: true });
            isHeaderHidden = false;
            document.documentElement.classList.remove('header-hidden');
          }
        } else if (delta > 0 && currentScrollY > 200) {
          // Bajando: Ocultar
          if (!isHeaderHidden) {
            gsap.to(navs, { y: -160, duration: 0.4, ease: 'power2.inOut', overwrite: true });
            isHeaderHidden = true;
            document.documentElement.classList.add('header-hidden');
          }
        } else if (delta < -15) {
          // Subiendo: Mostrar
          if (isHeaderHidden) {
            gsap.to(navs, { y: 0, duration: 0.3, ease: 'power2.out', overwrite: true });
            isHeaderHidden = false;
            document.documentElement.classList.remove('header-hidden');
          }
        }
        
        lastScrollY = currentScrollY;
      }, { passive: true });
    }
    initSmartHeader();
    document.addEventListener('astro:after-swap', initSmartHeader);
  </script>
</body>
</html>
