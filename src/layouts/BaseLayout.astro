---
import '../styles/global.css';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://barestanco.es/images/og-bar-estanco.svg'
} = Astro.props;

const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://barestanco.es${ogImage}`;

const siteName = 'Bar Estanco';
const isHome = title.includes('Vinoteca y Tapería');
const fullTitle = isHome
  ? 'Bar Estanco · Vinoteca y Tapería en Gondomar desde 1938'
  : `${title} · ${siteName}`;

// Schema.org LocalBusiness
const schemaData = {
  "@context": "https://schema.org",
  "@type": ["BarOrPub", "WineBar"],
  "name": "Bar Estanco",
  "description": "Vinoteca y tapería en Gondomar desde 1938. Más de 70 referencias de vino, vermuts, tapas gallegas y conservas premium. Tres generaciones de la misma familia. Bar Estanco.",
  "foundingDate": "1938",
  "url": "https://barestanco.es",
  "telephone": "+34986360098",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Pr. San Bieito, 1",
    "addressLocality": "Gondomar",
    "addressRegion": "Pontevedra",
    "postalCode": "36380",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.1131,
    "longitude": -8.7586
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "97",
    "bestRating": "5"
  },
  "award": [
    "Ganadores en la V Festa da Empanada de Gondomar (2017)",
    "Premio en concurso de tapas local"
  ],
  "hasMenu": {
    "@type": "Menu",
    "url": "https://barestanco.es/carta"
  },
  "servesCuisine": ["Tapas gallegas", "Vinos", "Vermuts", "Conservas gourmet", "Tapería"],
  "keywords": "bar estanco, vinoteca gondomar, tapería gondomar, vino gondomar, tapas gondomar, bar gondomar, vermut gondomar",
  "priceRange": "€€",
  "image": "https://barestanco.es/images/og-bar-estanco.svg",
  "sameAs": []
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO Primary -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />

  <!-- Geo & Local SEO -->
  <meta name="geo.region" content="ES-PO" />
  <meta name="geo.placename" content="Gondomar" />
  <meta name="geo.position" content="42.1131;-8.7586" />
  <meta name="ICBM" content="42.1131, -8.7586" />

  <!-- Theme & Mobile -->
  <meta name="theme-color" content="#1a1a1a" />
  <meta name="apple-mobile-web-app-title" content="Bar Estanco" />
  <meta name="application-name" content="Bar Estanco" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- Preload fuentes críticas (evita FOUT) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Cedarville+Cursive&display=swap" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</head>
<body class="min-h-screen flex flex-col">
  <Header />

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Fade-in observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
