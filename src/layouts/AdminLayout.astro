---
interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname;
const isCarta = path.startsWith('/admin/carta');
const isHorarios = path.startsWith('/admin/horarios');
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} — Admin · Bar Estanco</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sidebar-w: 220px;
      --header-h: 52px;
      --bottom-nav-h: 64px;
      --bg: #f7f6f3;
      --surface: #ffffff;
      --border: #e8e5e0;
      --ink: #1c1917;
      --ink-2: #57534e;
      --ink-3: #a8a29e;
      --wine: #7c2d12;
      --wine-light: #9a3412;
      --green: #15803d;
      --red: #dc2626;
      --red-bg: #fef2f2;
      --yellow: #d97706;
    }

    html, body { height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.5;
      -webkit-text-size-adjust: 100%;
    }

    /* ═══ LAYOUT SHELL ═══ */
    .admin-shell {
      display: flex;
      min-height: 100dvh;
    }

    /* ═══ SIDEBAR (desktop) ═══ */
    .admin-sidebar {
      width: var(--sidebar-w);
      background: #1c1917;
      color: #fff;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 40;
      flex-shrink: 0;
    }

    .sidebar-brand {
      padding: 1.25rem 1rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-brand-name {
      font-size: 0.95rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.01em;
    }
    .sidebar-brand-sub {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.4);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 0.15rem;
    }

    .sidebar-nav {
      flex: 1;
      padding: 0.75rem 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.6rem 0.75rem;
      border-radius: 8px;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      transition: all 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .sidebar-link:hover { color: #fff; background: rgba(255,255,255,0.08); }
    .sidebar-link.active { color: #fff; background: rgba(255,255,255,0.12); }
    .sidebar-link svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.7; }
    .sidebar-link.active svg { opacity: 1; }

    .sidebar-sep {
      height: 1px;
      background: rgba(255,255,255,0.08);
      margin: 0.5rem 0.75rem;
    }

    .sidebar-footer {
      padding: 0.75rem 0.5rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .sidebar-footer-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 0.75rem;
      border-radius: 8px;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      font-size: 0.78rem;
      cursor: pointer;
      border: none;
      background: none;
      width: 100%;
      text-align: left;
      transition: all 0.15s;
    }
    .sidebar-footer-link:hover { color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.06); }
    .sidebar-footer-link svg { width: 14px; height: 14px; flex-shrink: 0; }

    /* ═══ MOBILE HEADER ═══ */
    .admin-mobile-header {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-h);
      background: #1c1917;
      color: #fff;
      z-index: 40;
      align-items: center;
      justify-content: space-between;
      padding: 0 1rem;
    }
    .mobile-header-title {
      font-size: 0.9rem;
      font-weight: 600;
    }
    .mobile-header-actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .mobile-header-btn {
      background: none;
      border: none;
      color: rgba(255,255,255,0.7);
      cursor: pointer;
      padding: 0.4rem;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .mobile-header-btn:hover { color: #fff; background: rgba(255,255,255,0.1); }
    .mobile-header-btn svg { width: 18px; height: 18px; }

    /* Unsaved indicator */
    .unsaved-badge {
      display: none;
      background: #f87171;
      color: #fff;
      font-size: 0.6rem;
      font-weight: 700;
      padding: 0.1rem 0.4rem;
      border-radius: 10px;
      letter-spacing: 0.03em;
    }
    .unsaved-badge.visible { display: inline-block; }

    /* ═══ BOTTOM NAV (mobile) ═══ */
    .admin-bottom-nav {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: var(--bottom-nav-h);
      background: #1c1917;
      border-top: 1px solid rgba(255,255,255,0.08);
      z-index: 40;
    }
    .bottom-nav-inner {
      display: flex;
      height: 100%;
    }
    .bottom-nav-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.03em;
      transition: color 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .bottom-nav-item svg { width: 20px; height: 20px; }
    .bottom-nav-item.active { color: #fff; }
    .bottom-nav-item.active svg { stroke-width: 2.5; }

    /* ═══ MAIN CONTENT ═══ */
    .admin-content {
      flex: 1;
      margin-left: var(--sidebar-w);
      min-height: 100dvh;
    }
    .admin-main {
      max-width: 960px;
      margin: 0 auto;
      padding: 1.5rem 1.5rem;
    }

    /* ═══ PAGE HEADER ═══ */
    .page-title {
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 1.25rem;
    }

    /* ═══ FAB SAVE ═══ */
    .fab-save {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 45;
      background: var(--ink);
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 0.85rem 1.5rem;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      display: none;
      align-items: center;
      gap: 0.5rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
      transition: all 0.2s;
      -webkit-tap-highlight-color: transparent;
    }
    .fab-save:hover { background: #333; transform: translateY(-2px); box-shadow: 0 6px 24px rgba(0,0,0,0.35); }
    .fab-save:active { transform: translateY(0); }
    .fab-save.has-changes { background: var(--wine); }
    .fab-save.has-changes:hover { background: var(--wine-light); }
    .fab-save.saving { opacity: 0.7; pointer-events: none; }
    .fab-save svg { width: 16px; height: 16px; flex-shrink: 0; }

    /* ═══ TOAST ═══ */
    .toast {
      position: fixed;
      bottom: 5.5rem;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      padding: 0.75rem 1.25rem;
      border-radius: 10px;
      font-size: 0.85rem;
      font-weight: 500;
      color: #fff;
      z-index: 100;
      opacity: 0;
      transition: all 0.25s ease;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
      pointer-events: none;
    }
    .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
    .toast.success { background: var(--green); }
    .toast.error { background: var(--red); }

    /* ═══ CONFIRM MODAL ═══ */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      opacity: 0;
      transition: opacity 0.15s;
    }
    .modal-overlay.open { opacity: 1; }
    .modal-box {
      background: var(--surface);
      border-radius: 16px;
      padding: 1.75rem;
      max-width: 360px;
      width: 100%;
      box-shadow: 0 8px 40px rgba(0,0,0,0.2);
      text-align: center;
    }
    .modal-icon {
      width: 44px; height: 44px;
      background: var(--red-bg);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1rem;
    }
    .modal-icon svg { width: 22px; height: 22px; color: var(--red); }
    .modal-box h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
    .modal-box p { font-size: 0.85rem; color: var(--ink-2); margin-bottom: 1.5rem; line-height: 1.6; }
    .modal-actions { display: flex; gap: 0.75rem; }
    .modal-cancel {
      flex: 1; padding: 0.7rem; border-radius: 10px;
      background: var(--bg); border: 1px solid var(--border);
      color: var(--ink-2); font-size: 0.85rem; font-weight: 500; cursor: pointer;
      transition: all 0.15s;
    }
    .modal-cancel:hover { border-color: var(--ink-3); }
    .modal-confirm {
      flex: 1; padding: 0.7rem; border-radius: 10px;
      background: var(--red); border: 1px solid var(--red);
      color: #fff; font-size: 0.85rem; font-weight: 600; cursor: pointer;
      transition: all 0.15s;
    }
    .modal-confirm:hover { background: #b91c1c; }

    /* ═══ SHARED FORM STYLES ═══ */
    .card {
      background: var(--surface);
      border-radius: 12px;
      border: 1px solid var(--border);
      padding: 1.25rem;
      margin-bottom: 0.75rem;
    }

    .btn {
      display: inline-flex; align-items: center; gap: 0.35rem;
      padding: 0.5rem 1rem; border-radius: 8px;
      font-size: 0.8rem; font-weight: 500;
      border: 1px solid var(--border); background: var(--surface); color: var(--ink-2);
      cursor: pointer; transition: all 0.15s;
      -webkit-tap-highlight-color: transparent;
    }
    .btn:hover { background: var(--bg); border-color: var(--ink-3); color: var(--ink); }
    .btn:active { transform: scale(0.97); }
    .btn-primary { background: var(--ink); color: #fff; border-color: var(--ink); }
    .btn-primary:hover { background: #333; color: #fff; }
    .btn-danger { color: var(--red); border-color: #fca5a5; }
    .btn-danger:hover { background: var(--red-bg); border-color: var(--red); }
    .btn-sm { padding: 0.3rem 0.6rem; font-size: 0.72rem; border-radius: 6px; }

    input[type="text"], input[type="time"], input[type="number"], select, textarea {
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.875rem;
      font-family: inherit;
      width: 100%;
      background: var(--surface);
      color: var(--ink);
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: var(--ink);
      box-shadow: 0 0 0 3px rgba(28,25,23,0.08);
    }
    textarea { resize: vertical; min-height: 2.5rem; }
    .input-error { border-color: var(--red) !important; box-shadow: 0 0 0 3px rgba(220,38,38,0.1) !important; }

    label {
      display: block;
      font-size: 0.68rem;
      font-weight: 600;
      color: var(--ink-3);
      margin-bottom: 0.3rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 767px) {
      .admin-sidebar { display: none; }
      .admin-mobile-header { display: flex; }
      .admin-bottom-nav { display: block; }
      .admin-content { margin-left: 0; padding-top: var(--header-h); padding-bottom: var(--bottom-nav-h); }
      .admin-main { padding: 1rem 0.875rem; }
      .fab-save { bottom: calc(var(--bottom-nav-h) + 1rem); right: 1rem; }
      .toast { bottom: calc(var(--bottom-nav-h) + 4.5rem); }
      .card { padding: 1rem; border-radius: 10px; }
    }
  </style>
</head>
<body>
  <div class="admin-shell">

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-name">Bar Estanco</div>
        <div class="sidebar-brand-sub">Panel de administración</div>
      </div>

      <nav class="sidebar-nav">
        <a href="/admin/carta" class:list={['sidebar-link', { active: isCarta }]}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="1"/>
            <path d="M9 12h6M9 16h4"/>
          </svg>
          Carta
        </a>
        <a href="/admin/horarios" class:list={['sidebar-link', { active: isHorarios }]}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
          Horarios
        </a>
      </nav>

      <div class="sidebar-sep"></div>

      <div class="sidebar-footer">
        <a href="/" target="_blank" class="sidebar-footer-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Ver web
        </a>
        <button class="sidebar-footer-link" id="logout-btn" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Cerrar sesión
        </button>
      </div>
    </aside>

    <!-- ═══ CONTENT ═══ -->
    <div class="admin-content">

      <!-- Mobile header -->
      <header class="admin-mobile-header">
        <div class="mobile-header-title">{title}</div>
        <div class="mobile-header-actions">
          <span class="unsaved-badge" id="unsaved-badge">Sin guardar</span>
          <a href="/" target="_blank" class="mobile-header-btn" aria-label="Ver web">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
          <button class="mobile-header-btn" id="mobile-logout-btn" type="button" aria-label="Cerrar sesión">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
              <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </button>
        </div>
      </header>

      <main class="admin-main">
        <slot />
      </main>
    </div>

    <!-- Bottom nav (mobile) -->
    <nav class="admin-bottom-nav">
      <div class="bottom-nav-inner">
        <a href="/admin/carta" class:list={['bottom-nav-item', { active: isCarta }]}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="1"/>
            <path d="M9 12h6M9 16h4"/>
          </svg>
          Carta
        </a>
        <a href="/admin/horarios" class:list={['bottom-nav-item', { active: isHorarios }]}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
          Horarios
        </a>
      </div>
    </nav>
  </div>

  <!-- FAB Save -->
  <button class="fab-save" id="fab-save" type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
      <polyline points="17 21 17 13 7 13 7 21"/>
      <polyline points="7 3 7 8 15 8"/>
    </svg>
    <span>Guardar</span>
  </button>

  <!-- Toast -->
  <div id="toast" class="toast"></div>

  <!-- Confirm modal -->
  <div id="confirm-modal" class="modal-overlay" style="display:none;"></div>

  <script>
    // ── Toast ──
    window.showToast = function(message, type = 'success') {
      const toast = document.getElementById('toast');
      const icon = type === 'success' ? '✓' : '✗';
      toast.innerHTML = `<span>${icon}</span> ${message}`;
      toast.className = `toast ${type} show`;
      clearTimeout(window._toastTimer);
      window._toastTimer = setTimeout(() => toast.classList.remove('show'), 3500);
    };

    // ── Confirm modal ──
    window.showConfirm = function(title, message) {
      return new Promise((resolve) => {
        const modal = document.getElementById('confirm-modal');
        modal.innerHTML = `
          <div class="modal-box">
            <div class="modal-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 6h18M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/>
              </svg>
            </div>
            <h3>${title}</h3>
            <p>${message}</p>
            <div class="modal-actions">
              <button class="modal-cancel" type="button">Cancelar</button>
              <button class="modal-confirm" type="button">Eliminar</button>
            </div>
          </div>`;
        modal.style.display = 'flex';
        requestAnimationFrame(() => modal.classList.add('open'));
        const close = (r) => {
          modal.classList.remove('open');
          setTimeout(() => { modal.style.display = 'none'; }, 150);
          resolve(r);
        };
        modal.querySelector('.modal-cancel').onclick = () => close(false);
        modal.querySelector('.modal-confirm').onclick = () => close(true);
        modal.onclick = (e) => { if (e.target === modal) close(false); };
      });
    };

    // ── Unsaved ──
    window.setUnsaved = function(unsaved) {
      document.getElementById('unsaved-badge')?.classList.toggle('visible', unsaved);
      document.getElementById('fab-save')?.classList.toggle('has-changes', unsaved);
    };

    // ── FAB ──
    const fabSave = document.getElementById('fab-save');
    fabSave?.addEventListener('click', () => document.dispatchEvent(new CustomEvent('admin:save')));
    window.showFab = () => { if (fabSave) fabSave.style.display = 'flex'; };
    window.setFabSaving = (s) => {
      fabSave?.classList.toggle('saving', s);
      const span = fabSave?.querySelector('span');
      if (span) span.textContent = s ? 'Guardando…' : 'Guardar';
    };

    // ── Ctrl+S ──
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        document.dispatchEvent(new CustomEvent('admin:save'));
      }
    });

    // ── Logout ──
    async function doLogout() {
      await fetch('/api/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'logout' }),
      });
      window.location.href = '/admin';
    }
    document.getElementById('logout-btn')?.addEventListener('click', doLogout);
    document.getElementById('mobile-logout-btn')?.addEventListener('click', doLogout);
  </script>
</body>
</html>
