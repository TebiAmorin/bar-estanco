---
const currentYear = new Date().getFullYear();
---

<footer class="section-ink">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16">

    <!-- Main footer grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-8">

      <!-- Columna 1: Identidad -->
      <div class="col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-3">
          <div class="stamp-1938 border-paper/30 text-paper/80 scale-75">
            <div>
              <span class="stamp-1938-text">Desde</span>
              <span class="stamp-1938-year">1938</span>
            </div>
          </div>
          <div>
            <span class="font-display text-lg sm:text-xl font-bold text-paper leading-none">
              Bar Estanco
            </span>
          </div>
        </div>
        <p class="text-paper/60 text-sm leading-relaxed max-w-xs font-body">
          Un bar de toda la vida donde se sirve buen vino y se trata a la gente como en casa.
        </p>
      </div>

      <!-- Columna 2: Navegación -->
      <div>
        <h4 class="text-paper font-display text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-3 pb-2 border-b border-paper/10">Navegar</h4>
        <ul class="space-y-1">
          <li><a href="/carta" class="text-paper/60 hover:text-paper text-sm transition-colors inline-flex items-center min-h-[40px]">Carta de vinos</a></li>
          <li><a href="/carta/vermuts" class="text-paper/60 hover:text-paper text-sm transition-colors inline-flex items-center min-h-[40px]">Vermuts</a></li>
          <li><a href="/carta/tapas" class="text-paper/60 hover:text-paper text-sm transition-colors inline-flex items-center min-h-[40px]">Tapas y conservas</a></li>
          <li><a href="/contacto" class="text-paper/60 hover:text-paper text-sm transition-colors inline-flex items-center min-h-[40px]">Contacto</a></li>
        </ul>
      </div>

      <!-- Columna 3: Contacto -->
      <div>
        <h4 class="text-paper font-display text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-3 pb-2 border-b border-paper/10">Contacto</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2 text-paper/60">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-wine-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Pr. San Bieito, 1<br/>36380 Gondomar</span>
          </li>
          <li>
            <a href="tel:+34986360098" class="flex items-center gap-2 text-paper/60 hover:text-paper transition-colors min-h-[44px]">
              <svg class="w-4 h-4 shrink-0 text-wine-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              986 360 098
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Google -->
      <div class="col-span-2 lg:col-span-1">
        <h4 class="text-paper font-display text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-3 pb-2 border-b border-paper/10">Google</h4>
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map((star) => (
              <svg class:list={['w-4 h-4', star <= 4 ? 'text-wine-light' : 'text-paper/20']} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-paper text-sm font-semibold">4.6</span>
          <span class="text-paper/40 text-xs">/ 97 opiniones</span>
        </div>
        <a
          href="https://maps.google.com/?q=Bar+Estanco+Gondomar"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm text-wine-light hover:text-paper transition-colors min-h-[44px]"
        >
          Ver en Google Maps
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Separador editorial -->
    <div class="divider-editorial my-8 sm:my-10">
      <span class="divider-editorial-label text-paper/30">&middot;</span>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-paper/40">
      <p>&copy; {currentYear} Bar Estanco &middot; Gondomar</p>
      <p>
        <a href="/aviso-legal" class="hover:text-paper transition-colors min-h-[44px] inline-flex items-center">Aviso legal</a>
        <span class="mx-2">&middot;</span>
        <a href="/privacidad" class="hover:text-paper transition-colors min-h-[44px] inline-flex items-center">Privacidad</a>
      </p>
    </div>
  </div>
</footer>
