---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/carta', label: 'Carta' },
  { href: '/contacto', label: 'Contacto' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-paper/95 backdrop-blur-sm border-b border-ink/8" id="site-header" transition:persist role="banner">
  <nav class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-14 lg:h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="Bar Estanco - Inicio">
        <div class="stamp-1938 scale-[0.55] lg:scale-[0.65]">
          <div>
            <span class="stamp-1938-text">Desde</span>
            <span class="stamp-1938-year">1938</span>
          </div>
        </div>
        <div>
          <span class="font-display text-lg lg:text-xl font-bold text-ink leading-none">
            Bar Estanco
          </span>
          <span class="hidden sm:block text-[0.55rem] text-ink-faded tracking-[0.15em] uppercase">
            Vinoteca · Gondomar
          </span>
        </div>
      </a>

      <!-- Nav desktop -->
      <ul class="hidden lg:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 text-[0.7rem] font-display font-semibold tracking-[0.08em] uppercase transition-colors duration-200',
                isActive(link.href)
                  ? 'text-wine'
                  : 'text-ink-faded hover:text-wine'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Teléfono desktop + botones móvil -->
      <div class="flex items-center gap-1">
        <a
          href="tel:+34986360098"
          class="hidden lg:inline-flex items-center gap-1.5 text-[0.65rem] font-display font-semibold text-wine tracking-[0.08em] uppercase hover:text-wine-dark transition-colors"
        >
          986 360 098
        </a>

        <!-- Teléfono directo en móvil (icono) -->
        <a
          href="tel:+34986360098"
          class="lg:hidden p-2 text-wine min-w-[44px] min-h-[44px] flex items-center justify-center"
          aria-label="Llamar al 986 360 098"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>

        <!-- Hamburguesa -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-ink hover:text-wine transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg class="w-5 h-5 menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-5 h-5 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden hidden pb-3 border-t border-ink/8">
      <ul class="flex flex-col pt-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'flex items-center px-4 py-3 text-sm font-display font-semibold tracking-[0.08em] uppercase transition-colors min-h-[44px]',
                isActive(link.href)
                  ? 'text-wine bg-wine/5'
                  : 'text-ink-faded hover:text-wine active:bg-wine/5'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="mt-2 px-4">
          <a href="tel:+34986360098" class="btn-primary w-full justify-center">
            Llámanos · 986 360 098
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = menuBtn?.querySelector('.menu-icon');
  const closeIcon = menuBtn?.querySelector('.close-icon');

  function initHeader() {
    const h = document.getElementById('site-header');
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const mIcon = btn?.querySelector('.menu-icon');
    const cIcon = btn?.querySelector('.close-icon');

    window.addEventListener('scroll', () => {
      h?.classList.toggle('shadow-sm', window.scrollY > 10);
    });

    btn?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      mIcon?.classList.toggle('hidden');
      cIcon?.classList.toggle('hidden');
      btn?.setAttribute('aria-expanded', String(isOpen));
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
