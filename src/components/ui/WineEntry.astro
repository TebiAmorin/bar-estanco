---
import AllergenIcon from './AllergenIcon.astro';

interface Props {
  nombre: string;
  bodega?: string;
  tipo?: string;
  precio?: string;
  precioCopa?: string;
  descripcion?: string;
  destacado?: boolean;
  alergenos?: string[];
}

const { nombre, bodega, tipo, precio, precioCopa, descripcion, destacado = false, alergenos } = Astro.props;
---

<div class="wine-entry">
  <div class="flex-1 min-w-0">
    <div class="flex items-center flex-wrap gap-x-2 gap-y-1">
      <span class:list={['wine-entry-name', destacado && '!text-wine']}>
        {nombre}
      </span>
      {alergenos && alergenos.length > 0 && (
        <div class="flex items-center gap-1 ml-1 relative -top-[1px]">
          {alergenos.map(a => <AllergenIcon name={a} />)}
        </div>
      )}
    </div>
    {(bodega || tipo) && (
      <span class="wine-entry-detail">
        {bodega}{bodega && tipo ? ' · ' : ''}{tipo}
      </span>
    )}
  </div>
  {precio ? (
    <div class="flex items-center gap-2">
      {precioCopa && (
        <span class="copa-badge" title="Disponible por copa">
          <svg class="w-3.5 h-3.5 text-wine" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M8 2h8l-1 9H9L8 2z" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 11v6" stroke-linecap="round"/>
            <path d="M8 21h8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-[0.65rem] font-bold text-wine tracking-tighter">{precioCopa}&nbsp;&euro;</span>
        </span>
      )}
      <span class="wine-entry-price">{precio}&nbsp;&euro;</span>
    </div>
  ) : (
    <span class="price-consultar">Consultar</span>
  )}
</div>
{descripcion && destacado && (
  <p class="text-ink-faded text-xs italic mb-1 pl-0.5 font-body leading-relaxed -mt-1">{descripcion}</p>
)}
