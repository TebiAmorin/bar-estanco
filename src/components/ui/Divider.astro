---
interface Props {
  label?: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;
---

{label ? (
  <div class:list={['divider-editorial', className]}>
    <span class="divider-editorial-label">{label}</span>
  </div>
) : (
  <div class:list={['divider-editorial', className]}>
    <span class="divider-editorial-label">&#9671;</span>
  </div>
)}
