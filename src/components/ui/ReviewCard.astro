---
interface Props {
  author: string;
  text: string;
  rating: number;
  badge?: string;
}

const { author, text, rating, badge } = Astro.props;
---

<blockquote class="bg-paper-white/60 p-6 border-l-3 border-wine">
  <!-- Stars -->
  <div class="flex items-center gap-0.5 mb-3">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class:list={['w-4 h-4', i < rating ? 'text-wine' : 'text-paper-dark']}
        fill="currentColor"
        viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <p class="text-ink font-body text-sm sm:text-base leading-relaxed italic mb-4">
    &ldquo;{text}&rdquo;
  </p>

  <!-- Author -->
  <footer class="flex items-center gap-2">
    <div class="w-8 h-8 rounded-full bg-wine/10 flex items-center justify-center">
      <span class="text-wine text-xs font-semibold">
        {author.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()}
      </span>
    </div>
    <div>
      <cite class="text-ink text-sm font-semibold not-italic">{author}</cite>
      {badge && <span class="block text-ink-faded text-xs">{badge}</span>}
    </div>
  </footer>
</blockquote>
