---
interface Props {
  author: string;
  text: string;
  rating: number;
  badge?: string;
}

const { author, text, rating, badge } = Astro.props;
---

<blockquote class="bg-[#ebe3cf] p-1.5 border border-ink shadow-md relative mx-auto w-full max-w-2xl transform hover:scale-[1.01] transition-transform duration-300">
  <!-- Inner border line (Classic 1900s newspaper ad border) -->
  <div class="border border-ink p-6 sm:p-8 h-full flex flex-col justify-between bg-[#e6ddc5]">
    
    <!-- Vintage Header -->
    <div class="text-center mb-6">
      <div class="flex items-center justify-center gap-2 opacity-60 mb-2">
        <span class="block w-8 h-[1px] bg-ink"></span>
        <span class="text-ink text-xs leading-none">✦</span>
        <span class="block w-8 h-[1px] bg-ink"></span>
      </div>
      <span class="block text-ink font-display text-[0.6rem] sm:text-xs uppercase tracking-[0.4em] font-black">
        Testimonio Público
      </span>
      <div class="w-full h-[1px] bg-ink/30 mt-4"></div>
    </div>

    <!-- Body -->
    <p class="text-ink font-body text-base sm:text-lg leading-[1.9] text-justify mb-8">
      {text}
    </p>

    <!-- Footer: Author & Stars -->
    <footer class="text-center mt-auto border-t border-ink/30 pt-6">
      <cite class="text-ink font-display font-bold text-lg sm:text-xl uppercase tracking-widest not-italic block mb-2">
        — {author} —
      </cite>
      <div class="flex justify-center gap-1 text-ink mb-2 text-base opacity-80" aria-label={`${rating} estrellas`}>
        {Array.from({ length: 5 }).map((_, i) => (
          <span aria-hidden="true">{i < rating ? '★' : '☆'}</span>
        ))}
      </div>
      {badge && <span class="block text-ink/60 font-body italic text-[0.7rem] uppercase tracking-wider">{badge}</span>}
    </footer>

  </div>
</blockquote>
