---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'stamp-1938 scale-[0.7]',
  md: 'stamp-1938',
  lg: 'stamp-1938 stamp-1938-lg',
};
---

<div class:list={[sizeClasses[size], className]} aria-label="Desde 1938">
  <div>
    <span class="stamp-1938-text">Desde</span>
    <span class="stamp-1938-year">1938</span>
  </div>
</div>
