---
export const prerender = false;
import { verifySession } from "../../lib/auth";

const cookie = Astro.request.headers.get("cookie");
const isLoggedIn = await verifySession(cookie);
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Bar Estanco</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --ink: #1c1917;
        --ink-2: #57534e;
        --ink-3: #a8a29e;
        --bg: #f7f6f3;
        --surface: #fff;
        --border: #e8e5e0;
        --wine: #7c2d12;
        --red: #dc2626;
        --green: #15803d;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui,
          sans-serif;
        background: var(--bg);
        color: var(--ink);
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        -webkit-text-size-adjust: 100%;
      }

      /* ── LOGIN ── */
      .login-wrap {
        width: 100%;
        max-width: 380px;
      }
      .login-header {
        text-align: center;
        margin-bottom: 2rem;
      }
      .login-brand {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
      }
      .login-stamp {
        width: 64px;
        height: 64px;
        border: 2.5px solid var(--ink);
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0;
      }
      .login-stamp-text {
        font-size: 0.45rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--ink-2);
      }
      .login-stamp-year {
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--ink);
        line-height: 1;
      }
      .login-title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .login-sub {
        font-size: 0.75rem;
        color: var(--ink-3);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 0.2rem;
      }

      .login-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
      }
      .login-label {
        display: block;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--ink-3);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
      }
      .login-input {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        font-size: 1rem;
        font-family: inherit;
        color: var(--ink);
        background: var(--bg);
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      .login-input:focus {
        outline: none;
        border-color: var(--ink);
        background: var(--surface);
        box-shadow: 0 0 0 3px rgba(28, 25, 23, 0.08);
      }
      .login-btn {
        width: 100%;
        margin-top: 1rem;
        padding: 0.9rem;
        background: var(--ink);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: background 0.2s;
        -webkit-tap-highlight-color: transparent;
      }
      .login-btn:hover {
        background: #333;
      }
      .login-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .login-spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        display: none;
      }
      .login-btn.loading .login-spinner {
        display: block;
      }
      .login-btn.loading .login-text {
        display: none;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .error-msg {
        color: var(--red);
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 0.65rem 0.85rem;
        font-size: 0.8rem;
        margin-top: 0.75rem;
        display: none;
      }

      /* ── DASHBOARD ── */
      .dash-wrap {
        width: 100%;
        max-width: 480px;
      }
      .dash-header {
        text-align: center;
        margin-bottom: 2.5rem;
      }
      .dash-title {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.03em;
      }
      .dash-sub {
        font-size: 0.75rem;
        color: var(--ink-3);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 0.25rem;
      }

      .dash-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      .dash-card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        padding: 1.75rem 1.25rem;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s;
        -webkit-tap-highlight-color: transparent;
      }
      .dash-card:hover {
        border-color: var(--ink);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
      }
      .dash-card:active {
        transform: translateY(0);
      }
      .dash-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.875rem;
      }
      .dash-card-icon.wine {
        background: #fef3c7;
      }
      .dash-card-icon.clock {
        background: #dbeafe;
      }
      .dash-card-icon svg {
        width: 24px;
        height: 24px;
      }
      .dash-card-icon.wine svg {
        color: var(--wine);
      }
      .dash-card-icon.clock svg {
        color: #1d4ed8;
      }
      .dash-card h2 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
      }
      .dash-card p {
        font-size: 0.75rem;
        color: var(--ink-3);
        line-height: 1.4;
      }

      .dash-footer {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .dash-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem;
        border-radius: 10px;
        font-size: 0.8rem;
        color: var(--ink-2);
        text-decoration: none;
        border: 1px solid var(--border);
        background: var(--surface);
        transition: all 0.15s;
      }
      .dash-link:hover {
        color: var(--ink);
        border-color: var(--ink-3);
      }
      .dash-link svg {
        width: 14px;
        height: 14px;
      }
      .dash-logout {
        background: none;
        border: none;
        font-size: 0.78rem;
        color: var(--ink-3);
        cursor: pointer;
        padding: 0.5rem;
        margin-top: 0.25rem;
        transition: color 0.15s;
        font-family: inherit;
      }
      .dash-logout:hover {
        color: var(--red);
      }

      @media (max-width: 400px) {
        .dash-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    {
      isLoggedIn ? (
        <div class="dash-wrap">
          <div class="dash-header">
            <div class="dash-title">Bar Estanco</div>
            <div class="dash-sub">Panel de administración</div>
          </div>

          <div class="dash-grid">
            <a href="/admin/carta" class="dash-card">
              <div class="dash-card-icon wine">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                  <rect x="9" y="3" width="6" height="4" rx="1" />
                  <path d="M9 12h6M9 16h4" />
                </svg>
              </div>
              <h2>Carta</h2>
              <p>Vinos, vermuts, raciones y desayunos</p>
            </a>
            <a href="/admin/horarios" class="dash-card">
              <div class="dash-card-icon clock">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 6v6l4 2" />
                </svg>
              </div>
              <h2>Horarios</h2>
              <p>Días y franjas horarias</p>
            </a>
          </div>

          <div class="dash-footer">
            <a href="/" target="_blank" class="dash-link">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              Ver la web
            </a>
            <button class="dash-logout" id="logout-btn" type="button">
              Cerrar sesión
            </button>
          </div>
        </div>
      ) : (
        <div class="login-wrap">
          <div class="login-header">
            <div class="login-brand">
              <div class="login-stamp">
                <span class="login-stamp-text">Desde</span>
                <span class="login-stamp-year">1938</span>
              </div>
            </div>
            <div class="login-title">Bar Estanco</div>
            <div class="login-sub">Panel de administración</div>
          </div>

          <div class="login-card">
            <label class="login-label" for="password">
              Contraseña
            </label>
            <form id="login-form" autocomplete="on">
              <input
                type="password"
                id="password"
                class="login-input"
                placeholder="••••••••"
                autocomplete="current-password"
                required
                autofocus
              />
              <button type="submit" class="login-btn" id="login-btn">
                <span class="login-text">Entrar</span>
                <span class="login-spinner" />
              </button>
            </form>
            <div id="error-msg" class="error-msg" />
          </div>
        </div>
      )
    }

    <script>
      document
        .getElementById("login-form")
        ?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = document.getElementById("login-btn");
          const errEl = document.getElementById("error-msg");
          btn.disabled = true;
          btn.classList.add("loading");
          errEl.style.display = "none";
          try {
            const res = await fetch("/api/auth", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                password: document.getElementById("password").value,
              }),
            });
            const data = await res.json();
            if (res.ok) {
              window.location.reload();
            } else {
              errEl.textContent = data.error || "Contraseña incorrecta";
              errEl.style.display = "block";
              btn.classList.remove("loading");
              btn.disabled = false;
              document.getElementById("password").select();
            }
          } catch {
            errEl.textContent = "Error de conexión";
            errEl.style.display = "block";
            btn.classList.remove("loading");
            btn.disabled = false;
          }
        });

      document
        .getElementById("logout-btn")
        ?.addEventListener("click", async () => {
          await fetch("/api/auth", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "logout" }),
          });
          window.location.reload();
        });
    </script>
  </body>
</html>
