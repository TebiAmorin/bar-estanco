---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Carta">

  <!-- Category tabs -->
  <div id="tabs-bar" style="overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;margin-bottom:1rem;padding-bottom:2px;"></div>

  <!-- Loading -->
  <div id="loading" style="text-align:center;padding:3rem;color:#a8a29e;font-size:0.875rem;">Cargando carta…</div>

  <!-- Editor -->
  <div id="editor" style="display:none;">
    <div id="tab-content"></div>
  </div>

<style is:global>
  /* ── TABS ── */
  #tabs-bar { display:flex; gap:0.4rem; padding-bottom:0.5rem; }
  #tabs-bar::-webkit-scrollbar { display:none; }
  .tab-btn {
    flex-shrink:0;
    padding:0.45rem 0.9rem;
    border-radius:8px;
    font-size:0.78rem;
    font-weight:500;
    border:1.5px solid var(--border);
    background:var(--surface);
    color:var(--ink-2);
    cursor:pointer;
    white-space:nowrap;
    transition:all 0.15s;
    -webkit-tap-highlight-color:transparent;
  }
  .tab-btn:hover { border-color:var(--ink-3); color:var(--ink); }
  .tab-btn.active { background:var(--ink); color:#fff; border-color:var(--ink); }
  .tab-count { font-size:0.68rem; opacity:0.55; margin-left:0.2rem; }

  /* ── GROUP CARD ── */
  .group-card {
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:12px;
    margin-bottom:0.75rem;
    overflow:hidden;
  }
  .group-header {
    display:flex;
    align-items:center;
    gap:0.5rem;
    padding:0.75rem 1rem;
    background:#faf9f7;
    border-bottom:1px solid var(--border);
    cursor:pointer;
    -webkit-tap-highlight-color:transparent;
    user-select:none;
  }
  .group-header:hover { background:#f5f3ef; }
  .collapse-arrow { transition:transform 0.2s; flex-shrink:0; color:var(--ink-3); }
  .collapse-arrow.collapsed { transform:rotate(-90deg); }
  .group-name-input {
    flex:1;
    font-weight:600;
    font-size:0.875rem;
    border:1.5px solid transparent !important;
    padding:0.3rem 0.5rem !important;
    border-radius:6px !important;
    background:transparent;
  }
  .group-name-input:focus { border-color:var(--border) !important; background:var(--surface); }
  .group-count { font-size:0.68rem; color:var(--ink-3); white-space:nowrap; }
  .group-body.collapsed { display:none; }

  /* ── ADD BUTTONS ── */
  .add-item-btn {
    width:100%;
    display:flex; align-items:center; justify-content:center; gap:0.4rem;
    padding:0.75rem;
    border:none;
    border-top:1px solid var(--border);
    background:transparent;
    color:var(--ink-3);
    font-size:0.8rem; font-weight:500;
    cursor:pointer; transition:all 0.15s;
    -webkit-tap-highlight-color:transparent;
  }
  .add-item-btn:hover { background:#faf9f7; color:var(--ink); }
  .add-group-btn {
    width:100%;
    padding:0.85rem;
    border:2px dashed var(--border);
    border-radius:12px;
    background:transparent;
    color:var(--ink-3);
    font-size:0.85rem; font-weight:500;
    cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.4rem;
    transition:all 0.15s; margin-top:0.5rem;
    -webkit-tap-highlight-color:transparent;
  }
  .add-group-btn:hover { border-color:var(--ink); color:var(--ink); background:#faf9f7; }

  /* ── DESKTOP TABLE ── */
  .items-table { width:100%; border-collapse:collapse; font-size:0.8rem; }
  .items-table thead tr { border-bottom:1px solid var(--border); }
  .items-table th {
    padding:0.5rem 0.5rem;
    text-align:left;
    font-size:0.65rem; font-weight:600;
    color:var(--ink-3);
    text-transform:uppercase; letter-spacing:0.06em;
  }
  .items-table td { padding:0.3rem 0.35rem; vertical-align:middle; }
  .items-table tr { border-bottom:1px solid #f5f3ef; }
  .items-table tr:last-child { border-bottom:none; }
  .items-table input[type="text"] { font-size:0.8rem; padding:0.35rem 0.5rem; border-radius:6px; }
  .items-table input[type="checkbox"] { width:18px; height:18px; cursor:pointer; accent-color:var(--ink); }
  .col-precio { width:75px; }
  .col-copa { width:75px; }
  .col-dest { width:38px; text-align:center; }
  .col-sug  { width:50px; text-align:center; }
  .col-sug input { accent-color:#b8860b; }
  .col-hide { width:38px; text-align:center; }
  .col-hide input { accent-color:#dc2626; }
  .col-del { width:34px; }
  .is-oculto { opacity:0.45; }
  .is-oculto input[data-field="nombre"],
  .is-oculto .product-name-input { text-decoration:line-through; color:var(--ink-3); }

  /* ── DESC ROW ── */
  .desc-row td { padding:0 0.35rem 0.5rem !important; border-bottom:1px solid #f0ede8 !important; }
  .desc-input {
    font-size:0.78rem !important; padding:0.35rem 0.5rem !important;
    color:var(--ink-2); font-style:italic; min-height:2rem !important;
  }
  .desc-hint { font-size:0.62rem; color:var(--ink-3); margin-top:0.12rem; }
  .desc-hint.active { color:var(--green); }

  /* ── MOBILE PRODUCT CARDS ── */
  .product-card {
    border-bottom:1px solid var(--border);
    padding:0.875rem 1rem;
    position:relative;
  }
  .product-card:last-of-type { border-bottom:none; }

  /* Fila nombre + botón eliminar */
  .mc-header { display:flex; align-items:center; gap:0.5rem; margin-bottom:0.625rem; }
  .mc-name { flex:1; font-size:16px; font-weight:600; padding:0.55rem 0.7rem !important; }
  .mc-del { width:44px; height:44px; flex-shrink:0; background:none; border:none;
    cursor:pointer; color:var(--ink-3); border-radius:8px; transition:all 0.15s;
    display:flex; align-items:center; justify-content:center;
    -webkit-tap-highlight-color:transparent; }
  .mc-del:active { background:var(--red-bg); color:var(--red); }
  .mc-del svg { width:18px; height:18px; display:block; flex-shrink:0; }

  /* Grid de 2 columnas para campos */
  .mc-fields2 { display:grid; grid-template-columns:1fr 1fr; gap:0.5rem; margin-bottom:0.5rem; }
  .mc-lbl { display:block; font-size:0.6rem; font-weight:700; color:var(--ink-3);
    text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.25rem; }
  .mc-inp { width:100%; font-size:16px; padding:0.5rem 0.65rem; min-height:44px;
    border:1.5px solid var(--border); border-radius:8px; background:var(--surface);
    box-sizing:border-box; -webkit-appearance:none; appearance:none;
    color:var(--ink); }
  .mc-inp:focus { border-color:var(--ink); outline:none; box-shadow:0 0 0 3px rgba(0,0,0,0.05); }
  .mc-inp.input-error { border-color:var(--red); }

  /* Campo precio con símbolo € */
  .mc-price-wrap { position:relative; }
  .mc-price-wrap > span { position:absolute; right:0.6rem; top:50%;
    transform:translateY(-50%); font-size:0.75rem; color:var(--ink-3); pointer-events:none; }
  .mc-price { padding-right:1.6rem !important; }

  /* Pill buttons para toggles (destacado / copa / ocultar) */
  .mc-actions { display:flex; gap:0.35rem; flex-wrap:wrap; align-items:center; margin-top:0.5rem; }
  .toggle-pill { position:relative; display:inline-flex; align-items:center; gap:0.3rem;
    min-height:36px; padding:0 0.75rem; border-radius:20px;
    border:1.5px solid var(--border); background:transparent;
    color:var(--ink-2); font-size:0.72rem; font-weight:600;
    cursor:pointer; user-select:none; -webkit-tap-highlight-color:transparent;
    transition:all 0.12s; white-space:nowrap; }
  .toggle-pill input[type="checkbox"] { position:absolute; opacity:0; width:0; height:0; margin:0; }
  .tp-gold { border-color:#c8960a; background:#fffbeb; color:#92400e; }
  .tp-wine { border-color:#b8860b; background:#fdf4e3; color:#7a5c00; }
  .tp-red { border-color:var(--red); background:var(--red-bg); color:var(--red); }
  .tp-disabled { opacity:0.35; pointer-events:none; }

  /* Botón de descripción */
  .mc-desc-toggle { min-height:36px; padding:0 0.65rem; border-radius:20px;
    border:1.5px solid var(--border); background:transparent; color:var(--ink-3);
    font-size:0.72rem; font-weight:500; cursor:pointer; margin-left:auto;
    -webkit-tap-highlight-color:transparent; display:flex; align-items:center; gap:0.3rem; }
  .mc-desc-toggle:active { background:var(--bg); }

  /* Área descripción */
  .mc-desc-area { display:none; margin-top:0.5rem; }
  .mc-desc-area.open { display:block; }
  .mc-desc-area textarea { width:100%; font-size:16px; padding:0.5rem 0.65rem;
    border:1.5px solid var(--border); border-radius:8px; background:var(--surface);
    resize:vertical; box-sizing:border-box; min-height:64px; color:var(--ink); }

  @media (min-width:768px) {
    .product-card { display:none; }
    .items-table { display:table; }
  }
  @media (max-width:767px) {
    .items-table { display:none; }
    .product-card { display:block; }
  }
</style>

<script>
  const SECTIONS = [
    { key:'vinos.tintos',    label:'Tintos' },
    { key:'vinos.blancos',   label:'Blancos' },
    { key:'vinos.rosados',   label:'Rosados' },
    { key:'vinos.espumosos', label:'Espumosos' },
    { key:'vinos.sinAlcohol',label:'Sin Alcohol' },
    { key:'vermuts',         label:'Vermuts' },
    { key:'tapas',           label:'Raciones' },
    { key:'conservas',       label:'Conservas' },
    { key:'desayunos',       label:'Desayunos' },
  ];
  const VINO_KEYS = ['vinos.tintos','vinos.blancos','vinos.rosados','vinos.espumosos','vinos.sinAlcohol'];

  let carta = null;
  let activeTab = 'vinos.tintos';
  let hasChanges = false;
  let collapsedGroups = {};

  function getSection(data, key) {
    return key.split('.').reduce((o, k) => o[k], data);
  }
  function setSection(data, key, value) {
    const parts = key.split('.');
    let obj = data;
    for (let i = 0; i < parts.length - 1; i++) obj = obj[parts[i]];
    obj[parts[parts.length - 1]] = value;
  }
  function countItems(key) {
    try { return getSection(carta, key).reduce((s, g) => s + g.items.length, 0); }
    catch { return 0; }
  }
  function markChanged() {
    hasChanges = true;
    window.setUnsaved(true);
  }
  function validatePrice(v) {
    if (v === null || v === undefined || v === '' || v === 0) return true;
    return /^\d+([.,]\d{1,2})?$/.test(String(v).trim());
  }
  function countSugerencias() {
    return VINO_KEYS.reduce((total, key) => {
      try { return total + getSection(carta, key).reduce((s, g) => s + g.items.filter(i => i.sugerencia).length, 0); }
      catch { return total; }
    }, 0);
  }
  function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  /* ── TABS ── */
  function renderTabs() {
    const el = document.getElementById('tabs-bar');
    el.innerHTML = SECTIONS.map(s => {
      const count = countItems(s.key);
      return `<button class="tab-btn${s.key === activeTab ? ' active' : ''}" data-tab="${s.key}">
        ${s.label}<span class="tab-count">${count}</span>
      </button>`;
    }).join('');
    el.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => { activeTab = btn.dataset.tab; renderTabs(); renderContent(); });
    });
  }

  /* ── CONTENT ── */
  function renderContent() {
    const groups = getSection(carta, activeTab) ?? [];
    const isMobile = window.innerWidth < 768;
    const content = document.getElementById('tab-content');

    const groupsHTML = groups.map((group, gi) => {
      const isCollapsed = collapsedGroups[`${activeTab}-${gi}`];
      const itemsHTML = isMobile ? renderMobileItems(group, gi) : renderDesktopItems(group, gi);

      return `
      <div class="group-card" data-group="${gi}">
        <div class="group-header" data-gi="${gi}">
          <svg class="collapse-arrow${isCollapsed ? ' collapsed' : ''}" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
          <input type="text" class="group-name-input" value="${esc(group.do)}" data-field="do" data-gi="${gi}" onclick="event.stopPropagation()" />
          <span class="group-count">${group.items.length} items</span>
          <button class="btn btn-danger btn-sm" data-action="del-group" data-gi="${gi}" type="button" onclick="event.stopPropagation()">Eliminar</button>
        </div>
        <div class="group-body${isCollapsed ? ' collapsed' : ''}">
          ${itemsHTML}
          <button class="add-item-btn" data-action="add-item" data-gi="${gi}" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Añadir producto
          </button>
        </div>
      </div>`;
    }).join('');

    content.innerHTML = groupsHTML +
      `<button class="add-group-btn" id="add-group-btn" type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Añadir grupo
      </button>`;

    attachEvents(content);
  }

  function renderDesktopItems(group, gi) {
    if (activeTab === 'copa') {
      return `
      <table class="items-table">
        <thead><tr>
          <th>Nombre del vino</th>
          <th class="col-precio">Precio copa</th>
          <th class="col-del"></th>
        </tr></thead>
        <tbody>
          ${group.items.map((item, ii) => `
          <tr data-gi="${gi}" data-ii="${ii}">
            <td><input type="text" value="${esc(item.nombre)}" data-field="nombre" class="${item.nombre?.trim() ? '' : 'input-error'}" placeholder="Nombre del vino" /></td>
            <td class="col-precio"><input type="text" value="${esc(item.precio||'')}" data-field="precio" class="${validatePrice(item.precio)?'':'input-error'}" inputmode="decimal" placeholder="0.00" /></td>
            <td class="col-del"><button class="btn btn-danger btn-sm" data-action="del-item" data-gi="${gi}" data-ii="${ii}" type="button">✕</button></td>
          </tr>`).join('')}
        </tbody>
      </table>`;
    }
    const isVino = VINO_KEYS.includes(activeTab);
    const sugCount = isVino ? countSugerencias() : 0;
    return `
    <table class="items-table">
      <thead><tr>
        <th>Nombre</th><th>Bodega</th><th>Tipo</th>
        <th class="col-precio">Precio</th><th class="col-copa">Copa</th>
        <th class="col-dest">★</th>
        ${isVino ? `<th class="col-sug" title="Selección por copa (máx. 4) — ${sugCount}/4 activos">◆</th>` : ''}
        <th class="col-hide" title="Ocultar de la carta">🚫</th>
        <th class="col-del"></th>
      </tr></thead>
      <tbody>
        ${group.items.map((item, ii) => `
        <tr data-gi="${gi}" data-ii="${ii}"${item.oculto ? ' class="is-oculto"' : ''}>
          <td><input type="text" value="${esc(item.nombre)}" data-field="nombre" class="${item.nombre?.trim() ? '' : 'input-error'}" placeholder="Nombre" /></td>
          <td><input type="text" value="${esc(item.bodega||'')}" data-field="bodega" placeholder="—" /></td>
          <td><input type="text" value="${esc(item.tipo||'')}" data-field="tipo" placeholder="—" /></td>
          <td class="col-precio"><input type="text" value="${esc(String(item.precio||''))}" data-field="precio" class="${validatePrice(item.precio)?'':'input-error'}" inputmode="decimal" placeholder="0.00" /></td>
          <td class="col-copa"><input type="text" value="${esc(String(item.precioCopa||''))}" data-field="precioCopa" class="${validatePrice(item.precioCopa)?'':'input-error'}" inputmode="decimal" placeholder="—" /></td>
          <td class="col-dest"><input type="checkbox" ${item.destacado?'checked':''} data-field="destacado" /></td>
          ${isVino ? `<td class="col-sug"><input type="checkbox" ${item.sugerencia?'checked':''} data-field="sugerencia" ${!item.sugerencia && sugCount >= 4 ? 'disabled title="Máximo 4 activos"' : ''} /></td>` : ''}
          <td class="col-hide"><input type="checkbox" ${item.oculto?'checked':''} data-field="oculto" title="${item.oculto?'Oculto — clic para mostrar en carta':'Visible — clic para ocultar'}" /></td>
          <td class="col-del"><button class="btn btn-danger btn-sm" data-action="del-item" data-gi="${gi}" data-ii="${ii}" type="button">✕</button></td>
        </tr>
        <tr class="desc-row" data-gi="${gi}" data-ii="${ii}">
          <td colspan="${isVino ? 9 : 8}">
            <textarea class="desc-input" data-field="descripcion" data-gi="${gi}" data-ii="${ii}" rows="1" placeholder="Descripción (opcional)">${esc(item.descripcion||'')}</textarea>
            <div class="desc-hint${item.destacado&&item.descripcion?' active':''}">${item.destacado?(item.descripcion?'✓ Visible en la web':'Solo si añades texto'):'Solo visible si ★ destacado'}</div>
          </td>
        </tr>`).join('')}
      </tbody>
    </table>`;
  }

  function renderMobileItems(group, gi) {
    const delIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/></svg>`;
    const descIcon = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;

    if (activeTab === 'copa') {
      return group.items.map((item, ii) => `
      <div class="product-card" data-gi="${gi}" data-ii="${ii}">
        <div class="mc-header">
          <input type="text" class="mc-name ${item.nombre?.trim()?'':'input-error'}" value="${esc(item.nombre)}" data-field="nombre" data-gi="${gi}" data-ii="${ii}" placeholder="Nombre del vino" autocomplete="off" />
          <button class="mc-del" data-action="del-item" data-gi="${gi}" data-ii="${ii}" type="button" aria-label="Eliminar">${delIcon}</button>
        </div>
        <div>
          <label class="mc-lbl">Precio copa</label>
          <div class="mc-price-wrap">
            <input type="text" class="mc-inp mc-price ${validatePrice(item.precio)?'':'input-error'}" value="${esc(item.precio||'')}" data-field="precio" data-gi="${gi}" data-ii="${ii}" inputmode="decimal" placeholder="0,00" autocomplete="off" />
            <span>€</span>
          </div>
        </div>
      </div>`).join('');
    }

    const isVino = VINO_KEYS.includes(activeTab);
    const sugCount = isVino ? countSugerencias() : 0;

    return group.items.map((item, ii) => `
    <div class="product-card${item.oculto?' is-oculto':''}" data-gi="${gi}" data-ii="${ii}">

      <div class="mc-header">
        <input type="text" class="mc-name ${item.nombre?.trim()?'':'input-error'}"
          value="${esc(item.nombre)}" data-field="nombre" data-gi="${gi}" data-ii="${ii}"
          placeholder="Nombre del producto"
          autocomplete="off" autocorrect="off" autocapitalize="words" enterkeyhint="next" />
        <button class="mc-del" data-action="del-item" data-gi="${gi}" data-ii="${ii}"
          type="button" aria-label="Eliminar">${delIcon}</button>
      </div>

      <div class="mc-fields2">
        <div>
          <label class="mc-lbl">Bodega</label>
          <input type="text" class="mc-inp" value="${esc(item.bodega||'')}" data-field="bodega"
            data-gi="${gi}" data-ii="${ii}" placeholder="—" autocomplete="off" enterkeyhint="next" />
        </div>
        <div>
          <label class="mc-lbl">Tipo / D.O.</label>
          <input type="text" class="mc-inp" value="${esc(item.tipo||'')}" data-field="tipo"
            data-gi="${gi}" data-ii="${ii}" placeholder="—" autocomplete="off" enterkeyhint="next" />
        </div>
      </div>

      <div class="mc-fields2">
        <div>
          <label class="mc-lbl">Precio botella</label>
          <div class="mc-price-wrap">
            <input type="text" class="mc-inp mc-price ${validatePrice(item.precio)?'':'input-error'}"
              value="${esc(String(item.precio||''))}" data-field="precio" data-gi="${gi}" data-ii="${ii}"
              inputmode="decimal" placeholder="0,00" autocomplete="off" enterkeyhint="next" />
            <span>€</span>
          </div>
        </div>
        <div>
          <label class="mc-lbl">Por copa</label>
          <div class="mc-price-wrap">
            <input type="text" class="mc-inp mc-price ${validatePrice(item.precioCopa)?'':'input-error'}"
              value="${esc(String(item.precioCopa||''))}" data-field="precioCopa" data-gi="${gi}" data-ii="${ii}"
              inputmode="decimal" placeholder="—" autocomplete="off" enterkeyhint="done" />
            <span>€</span>
          </div>
        </div>
      </div>

      <div class="mc-actions">
        <label class="toggle-pill${item.destacado?' tp-gold':''}">
          <input type="checkbox" ${item.destacado?'checked':''} data-field="destacado" data-gi="${gi}" data-ii="${ii}" />
          ★ Destacado
        </label>
        ${isVino ? `<label class="toggle-pill${item.sugerencia?' tp-wine':''}${!item.sugerencia&&sugCount>=4?' tp-disabled':''}">
          <input type="checkbox" ${item.sugerencia?'checked':''} data-field="sugerencia" data-gi="${gi}" data-ii="${ii}" ${!item.sugerencia&&sugCount>=4?'disabled':''} />
          ◆ Copa
        </label>` : ''}
        <label class="toggle-pill${item.oculto?' tp-red':''}">
          <input type="checkbox" ${item.oculto?'checked':''} data-field="oculto" data-gi="${gi}" data-ii="${ii}" />
          🚫 Ocultar
        </label>
        <button class="mc-desc-toggle" data-toggle-desc="${gi}-${ii}" type="button">
          ${descIcon} Desc.
        </button>
      </div>

      <div class="mc-desc-area${item.descripcion?' open':''}" id="desc-${gi}-${ii}">
        <textarea data-field="descripcion" data-gi="${gi}" data-ii="${ii}"
          rows="2" placeholder="Descripción (visible si el producto está destacado)"
          >${esc(item.descripcion||'')}</textarea>
      </div>

    </div>`).join('');
  }

  /* ── EVENT ATTACHMENT ── */
  function attachEvents(content) {
    // Collapse/expand
    content.querySelectorAll('.group-header').forEach(header => {
      header.addEventListener('click', (e) => {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
        const gi = parseInt(header.dataset.gi);
        const key = `${activeTab}-${gi}`;
        collapsedGroups[key] = !collapsedGroups[key];
        header.nextElementSibling.classList.toggle('collapsed');
        header.querySelector('.collapse-arrow').classList.toggle('collapsed');
      });
    });

    // Desc toggle (mobile)
    content.querySelectorAll('[data-toggle-desc]').forEach(btn => {
      btn.addEventListener('click', () => {
        const [gi, ii] = btn.dataset.toggleDesc.split('-');
        const area = document.getElementById(`desc-${gi}-${ii}`);
        area?.classList.toggle('open');
      });
    });

    // Input changes
    content.querySelectorAll('input, textarea').forEach(input => {
      const handler = (e) => {
        const field = e.target.dataset.field;
        const gi = parseInt(e.target.dataset.gi ?? e.target.closest('[data-gi]')?.dataset.gi ?? e.target.closest('[data-group]')?.dataset.group);
        const ii = parseInt(e.target.dataset.ii ?? e.target.closest('[data-ii]')?.dataset.ii);

        if (field === 'do') {
          getSection(carta, activeTab)[gi].do = e.target.value;
          markChanged();
          return;
        }
        if (isNaN(ii)) return;

        const item = getSection(carta, activeTab)[gi]?.items[ii];
        if (!item) return;

        if (field === 'destacado') {
          item.destacado = e.target.checked;
          renderContent();
          return;
        }
        if (field === 'sugerencia') {
          if (e.target.checked && countSugerencias() >= 4) {
            e.target.checked = false;
            window.showToast('Máximo 4 vinos en Selección por Copa', 'error');
            return;
          }
          item.sugerencia = e.target.checked;
          markChanged();
          renderContent();
          return;
        }
        if (field === 'oculto') {
          item.oculto = e.target.checked;
          markChanged();
          renderContent();
          return;
        }
        if (['precioCopa','tipo','bodega','descripcion'].includes(field)) {
          item[field] = e.target.value || null;
        } else if (field === 'precio') {
          item.precio = e.target.value;
          e.target.classList.toggle('input-error', !validatePrice(e.target.value));
        } else if (field === 'nombre') {
          item.nombre = e.target.value;
          e.target.classList.toggle('input-error', !e.target.value.trim());
        } else {
          item[field] = e.target.value;
        }
        markChanged();
      };
      if (input.tagName === 'TEXTAREA' || input.dataset.field === 'descripcion') {
        input.addEventListener('input', handler);
      } else {
        input.addEventListener('change', handler);
      }
      if (['precio','precioCopa'].includes(input.dataset.field)) {
        input.addEventListener('blur', () => input.classList.toggle('input-error', !validatePrice(input.value)));
      }
      if (input.dataset.field === 'nombre') {
        input.addEventListener('blur', () => input.classList.toggle('input-error', !input.value.trim()));
      }
    });

    // Delete item
    content.querySelectorAll('[data-action="del-item"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const gi = parseInt(btn.dataset.gi);
        const ii = parseInt(btn.dataset.ii);
        const items = getSection(carta, activeTab)[gi].items;
        const name = items[ii].nombre || 'este producto';
        if (await window.showConfirm('¿Eliminar producto?', `Se eliminará <strong>"${esc(name)}"</strong> de la carta.`)) {
          items.splice(ii, 1);
          markChanged();
          renderTabs();
          renderContent();
        }
      });
    });

    // Add item
    content.querySelectorAll('[data-action="add-item"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const gi = parseInt(btn.dataset.gi);
        const newItem = activeTab === 'copa'
          ? { nombre:'', precio:'' }
          : { nombre:'', bodega:'', tipo:null, precio:'', precioCopa:null, destacado:false, sugerencia:false, oculto:false, descripcion:null };
        getSection(carta, activeTab)[gi].items.push(newItem);
        markChanged();
        renderTabs();
        renderContent();
        setTimeout(() => {
          const cards = content.querySelectorAll(`[data-group="${gi}"] .product-card, [data-group="${gi}"] tbody tr`);
          const last = cards[cards.length - 2]; // skip desc row
          if (last) {
            last.scrollIntoView({ behavior:'smooth', block:'center' });
            const nameInput = last.querySelector('input[data-field="nombre"]');
            nameInput?.focus();
          }
        }, 50);
      });
    });

    // Delete group
    content.querySelectorAll('[data-action="del-group"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const gi = parseInt(btn.dataset.gi);
        const groups = getSection(carta, activeTab);
        const name = groups[gi].do || 'este grupo';
        const count = groups[gi].items.length;
        if (await window.showConfirm('¿Eliminar grupo?', `Se eliminará <strong>"${esc(name)}"</strong> y sus ${count} producto${count!==1?'s':''}.`)) {
          groups.splice(gi, 1);
          markChanged();
          renderTabs();
          renderContent();
        }
      });
    });

    // Add group
    document.getElementById('add-group-btn')?.addEventListener('click', () => {
      getSection(carta, activeTab).push({ do:'Nuevo grupo', items:[] });
      markChanged();
      renderTabs();
      renderContent();
      setTimeout(() => {
        const cards = content.querySelectorAll('.group-card');
        cards[cards.length-1]?.scrollIntoView({ behavior:'smooth', block:'center' });
      }, 50);
    });
  }

  /* ── SAVE ── */
  async function save() {
    const errors = document.querySelectorAll('.input-error').length;
    if (errors > 0) {
      window.showToast(`${errors} campo${errors>1?'s':''} con errores. Revísalos primero.`, 'error');
      return;
    }
    window.setFabSaving(true);
    try {
      const res = await fetch('/api/carta', {
        method:'PUT',
        headers:{ 'Content-Type':'application/json' },
        body:JSON.stringify(carta),
      });
      if (res.ok) {
        hasChanges = false;
        window.setUnsaved(false);
        window.showToast('Carta guardada ✓');
      } else {
        const data = await res.json();
        window.showToast(data.error || 'Error al guardar', 'error');
      }
    } catch { window.showToast('Error de conexión', 'error'); }
    window.setFabSaving(false);
  }

  document.addEventListener('admin:save', save);
  window.addEventListener('beforeunload', (e) => {
    if (hasChanges) { e.preventDefault(); e.returnValue = ''; }
  });
  window.addEventListener('resize', () => { if (carta) renderContent(); });

  /* ── INIT ── */
  async function init() {
    try {
      const res = await fetch('/api/carta');
      if (!res.ok) throw new Error('No autorizado');
      carta = await res.json();
      SECTIONS.forEach(s => {
        try {
          getSection(carta, s.key).forEach((_g, i) => {
            if (i > 0) collapsedGroups[`${s.key}-${i}`] = true;
          });
        } catch {}
      });
      document.getElementById('loading').style.display = 'none';
      document.getElementById('editor').style.display = 'block';
      window.showFab();
      renderTabs();
      renderContent();
    } catch(e) {
      document.getElementById('loading').innerHTML = `<span style="color:#dc2626">Error: ${e.message}</span>`;
    }
  }
  init();
</script>

</AdminLayout>
