---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Horarios">

  <div id="loading" style="text-align:center;padding:3rem;color:#a8a29e;font-size:0.875rem;">Cargando horarios…</div>

  <div id="editor" style="display:none;">
    <div id="day-cards"></div>
    <button class="add-day-btn" id="add-day-btn" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Añadir día
    </button>

    <!-- Preview -->
    <div class="preview-card">
      <div class="preview-label">Vista previa — así se verá en la web</div>
      <div id="preview-content"></div>
    </div>
  </div>

<style is:global>
  .add-day-btn {
    width:100%;
    padding:0.875rem;
    border:2px dashed var(--border);
    border-radius:12px;
    background:transparent;
    color:var(--ink-3);
    font-size:0.875rem; font-weight:500;
    cursor:pointer;
    display:flex; align-items:center; justify-content:center; gap:0.5rem;
    transition:all 0.15s; margin-bottom:1.25rem;
    -webkit-tap-highlight-color:transparent;
  }
  .add-day-btn:hover { border-color:var(--ink); color:var(--ink); background:#faf9f7; }

  /* Day card */
  .day-card {
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:12px;
    margin-bottom:0.75rem;
    overflow:hidden;
  }
  .day-header {
    display:flex; align-items:center; gap:0.75rem;
    padding:0.875rem 1rem;
    background:#faf9f7;
    border-bottom:1px solid var(--border);
  }
  .day-name-input {
    flex:1;
    font-weight:600; font-size:0.95rem;
    border:1.5px solid transparent !important;
    padding:0.35rem 0.5rem !important;
    border-radius:6px !important;
    background:transparent;
  }
  .day-name-input:focus { border-color:var(--border) !important; background:var(--surface); }
  .day-body { padding:1rem; display:flex; flex-direction:column; gap:0.5rem; }

  /* Turno */
  .turno-block {
    background:var(--bg);
    border:1px solid var(--border);
    border-radius:8px;
    padding:0.75rem;
  }
  .turno-top {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:0.6rem;
  }
  .turno-label {
    font-size:0.68rem; font-weight:600; color:var(--ink-3);
    text-transform:uppercase; letter-spacing:0.06em;
  }
  .turno-times {
    display:grid; grid-template-columns:1fr auto 1fr; align-items:end; gap:0.5rem;
  }
  .turno-sep {
    font-size:1.1rem; color:var(--ink-3); text-align:center;
    padding-bottom:0.55rem; line-height:1;
  }
  .time-field label { font-size:0.65rem; font-weight:600; color:var(--ink-3); margin-bottom:0.3rem; text-transform:uppercase; letter-spacing:0.06em; }
  .time-field input[type="time"] { font-size:1rem; padding:0.6rem 0.75rem; border-radius:8px; }
  .turno-error {
    font-size:0.72rem; color:var(--red); margin-top:0.35rem; display:none;
  }
  .turno-error.visible { display:block; }

  .add-turno-btn {
    width:100%; padding:0.6rem;
    border:1.5px dashed var(--border); border-radius:8px;
    background:transparent; color:var(--ink-3);
    font-size:0.78rem; font-weight:500;
    cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.35rem;
    transition:all 0.15s; -webkit-tap-highlight-color:transparent;
  }
  .add-turno-btn:hover { border-color:var(--ink); color:var(--ink); }

  /* Preview */
  .preview-card {
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:12px;
    padding:1.25rem;
    margin-top:0.25rem;
  }
  .preview-label {
    font-size:0.68rem; font-weight:600; color:var(--ink-3);
    text-transform:uppercase; letter-spacing:0.08em;
    margin-bottom:1rem;
  }
  .preview-row {
    display:flex; justify-content:space-between; align-items:baseline;
    padding:0.5rem 0; border-bottom:1px solid var(--bg);
    font-size:0.875rem;
  }
  .preview-row:last-child { border-bottom:none; }
  .preview-day { font-weight:600; }
  .preview-time { color:var(--ink-2); text-align:right; }
  .preview-empty { font-size:0.8rem; color:var(--ink-3); font-style:italic; text-align:center; padding:1rem; }

  @media (max-width:767px) {
    .turno-times { grid-template-columns:1fr 1fr; }
    .turno-sep { display:none; }
  }
</style>

<script>
  let horarios = null;
  let hasChanges = false;

  function markChanged() { hasChanges = true; window.setUnsaved(true); }
  function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function validateTurno(t) {
    if (!t[0] || !t[1]) return null;
    return t[1] > t[0] ? null : 'La hora de cierre debe ser posterior a la de apertura';
  }

  function render() {
    const container = document.getElementById('day-cards');
    container.innerHTML = horarios.map((h, i) => `
      <div class="day-card" data-i="${i}">
        <div class="day-header">
          <input type="text" class="day-name-input" value="${esc(h.dia)}" data-field="dia" data-i="${i}" placeholder="Ej: Lunes, Martes – Viernes…" />
          <button class="btn btn-danger btn-sm" data-action="del-day" data-i="${i}" type="button">Eliminar</button>
        </div>
        <div class="day-body">
          ${h.turnos.map((t, ti) => {
            const error = validateTurno(t);
            const label = h.turnos.length === 1 ? 'Horario' : ti === 0 ? 'Turno de mañana' : 'Turno de tarde';
            return `
            <div class="turno-block" data-i="${i}" data-ti="${ti}">
              <div class="turno-top">
                <span class="turno-label">${label}</span>
                ${h.turnos.length > 1 ? `
                  <button class="btn btn-danger btn-sm" data-action="del-turno" data-i="${i}" data-ti="${ti}" type="button" style="padding:0.2rem 0.5rem;font-size:0.68rem;">Quitar turno</button>
                ` : ''}
              </div>
              <div class="turno-times">
                <div class="time-field">
                  <label>Apertura</label>
                  <input type="time" value="${t[0]||''}" data-turno="${ti}" data-pos="0" class="${!t[0]&&t[1]?'input-error':''}" />
                </div>
                <div class="turno-sep">→</div>
                <div class="time-field">
                  <label>Cierre</label>
                  <input type="time" value="${t[1]||''}" data-turno="${ti}" data-pos="1" class="${(!t[1]&&t[0])||error?'input-error':''}" />
                </div>
              </div>
              <div class="turno-error${error?' visible':''}">${error||''}</div>
            </div>`;
          }).join('')}
          ${h.turnos.length < 3 ? `
            <button class="add-turno-btn" data-action="add-turno" data-i="${i}" type="button">
              + Añadir turno${h.turnos.length===1?' tarde':''}
            </button>` : ''}
        </div>
      </div>
    `).join('');

    renderPreview();
    attachEvents();
  }

  function renderPreview() {
    const el = document.getElementById('preview-content');
    if (!horarios?.length) { el.innerHTML = '<div class="preview-empty">Sin horarios configurados</div>'; return; }
    el.innerHTML = horarios.map(h => {
      const times = h.turnos.filter(t => t[0]&&t[1]).map(t => `${t[0]} – ${t[1]}`).join(' / ');
      return `<div class="preview-row">
        <span class="preview-day">${esc(h.dia)}</span>
        <span class="preview-time">${times||'—'}</span>
      </div>`;
    }).join('');
  }

  function attachEvents() {
    const container = document.getElementById('day-cards');

    container.querySelectorAll('input').forEach(input => {
      input.addEventListener('change', (e) => {
        const card = e.target.closest('.day-card');
        const i = parseInt(card.dataset.i);
        const field = e.target.dataset.field;
        if (field === 'dia') {
          horarios[i].dia = e.target.value;
        } else {
          const ti = parseInt(e.target.dataset.turno);
          const pos = parseInt(e.target.dataset.pos);
          if (horarios[i].turnos[ti]) horarios[i].turnos[ti][pos] = e.target.value;
          // Validate
          const turno = horarios[i].turnos[ti];
          const error = validateTurno(turno);
          const block = e.target.closest('.turno-block');
          const errEl = block?.querySelector('.turno-error');
          if (errEl) { errEl.textContent = error||''; errEl.classList.toggle('visible', !!error); }
          const inputs = block?.querySelectorAll('input[type="time"]');
          if (inputs?.length === 2) {
            inputs[0].classList.toggle('input-error', !turno[0] && !!turno[1]);
            inputs[1].classList.toggle('input-error', (!turno[1] && !!turno[0]) || !!error);
          }
        }
        markChanged();
        renderPreview();
      });
    });

    container.querySelectorAll('[data-action="add-turno"]').forEach(btn => {
      btn.addEventListener('click', () => {
        horarios[parseInt(btn.dataset.i)].turnos.push(['','']);
        markChanged(); render();
      });
    });
    container.querySelectorAll('[data-action="del-turno"]').forEach(btn => {
      btn.addEventListener('click', () => {
        horarios[parseInt(btn.dataset.i)].turnos.splice(parseInt(btn.dataset.ti),1);
        markChanged(); render();
      });
    });
    container.querySelectorAll('[data-action="del-day"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const i = parseInt(btn.dataset.i);
        const name = horarios[i].dia || 'este día';
        if (await window.showConfirm('¿Eliminar día?', `Se eliminará <strong>"${esc(name)}"</strong> y todos sus turnos.`)) {
          horarios.splice(i, 1);
          markChanged(); render();
        }
      });
    });

    document.getElementById('add-day-btn')?.addEventListener('click', () => {
      horarios.push({ dia:'Nuevo día', turnos:[['','']] });
      markChanged(); render();
      setTimeout(() => {
        const cards = container.querySelectorAll('.day-card');
        const last = cards[cards.length-1];
        if (last) { last.scrollIntoView({ behavior:'smooth', block:'center' }); last.querySelector('.day-name-input')?.focus(); }
      }, 50);
    });
  }

  async function save() {
    let errors = 0;
    horarios.forEach(h => h.turnos.forEach(t => {
      if ((t[0]&&!t[1])||(!t[0]&&t[1])) errors++;
      if (t[0]&&t[1]&&t[1]<=t[0]) errors++;
    }));
    if (errors > 0) { window.showToast(`${errors} turno${errors>1?'s':''} con errores.`, 'error'); return; }

    window.setFabSaving(true);
    try {
      const res = await fetch('/api/horarios', {
        method:'PUT',
        headers:{ 'Content-Type':'application/json' },
        body:JSON.stringify(horarios),
      });
      if (res.ok) {
        hasChanges = false;
        window.setUnsaved(false);
        window.showToast('Horarios guardados ✓');
      } else {
        const data = await res.json();
        window.showToast(data.error||'Error al guardar','error');
      }
    } catch { window.showToast('Error de conexión','error'); }
    window.setFabSaving(false);
  }

  document.addEventListener('admin:save', save);
  window.addEventListener('beforeunload', (e) => { if (hasChanges) { e.preventDefault(); e.returnValue=''; } });

  async function init() {
    try {
      const res = await fetch('/api/horarios');
      if (!res.ok) throw new Error('No autorizado');
      horarios = await res.json();
      document.getElementById('loading').style.display = 'none';
      document.getElementById('editor').style.display = 'block';
      window.showFab();
      render();
    } catch(e) {
      document.getElementById('loading').innerHTML = `<span style="color:#dc2626">Error: ${e.message}</span>`;
    }
  }
  init();
</script>

</AdminLayout>
