---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Divider from '../components/ui/Divider.astro';
import { getHorarios } from '../lib/kv';

const horarios = await getHorarios();
---

<BaseLayout
  title="Contacto — Café Bar y Tapería en Gondomar"
  description="Cómo llegar a Bar Estanco, café bar, vinoteca y tapería en Gondomar. Rúa San Bieito, 1, 36380 Gondomar, Pontevedra. Teléfono 986 360 098. Centro de Gondomar."
>

  <!-- Header Simple -->
  <section class="section-ink py-12 sm:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label border-paper/20 text-paper/50 mb-4 uppercase tracking-[0.2em]">Contacto</span>
      <h1 class="text-paper text-4xl sm:text-6xl font-bold mt-4 mb-4">Visítanos en la plaza</h1>
      <p class="text-paper-dark/70 max-w-lg mx-auto font-body text-base">
        Estamos en el centro de Gondomar. Reservas solo por teléfono.
      </p>
    </div>
  </section>


  <section class="py-12 sm:py-20 px-4 bg-paper">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-start">

        <!-- Info (Columna Izquierda) -->
        <div class="fade-in space-y-12">
          
          <div>
            <h2 class="font-display text-2xl mb-6 border-b border-ink/10 pb-2">Datos de contacto</h2>
            
            <div class="space-y-8">
              <!-- Dirección -->
              <div>
                <span class="text-wine font-display text-xs uppercase tracking-widest block mb-2">Ubicación</span>
                <p class="text-ink text-xl font-body">
                  Rúa San Bieito, 1<br />
                  36380 Gondomar, Pontevedra
                </p>
              </div>

              <!-- Teléfono -->
              <div>
                <span class="text-wine font-display text-xs uppercase tracking-widest block mb-2">Teléfono</span>
                <a href="tel:+34986360098" class="text-ink text-3xl font-display font-bold hover:text-wine transition-colors">
                  986 360 098
                </a>
              </div>
            </div>
          </div>

          <!-- Horario -->
          <div class="bg-paper-dark/30 p-6 sm:p-8 border-l-4 border-wine">
            <h2 class="font-display text-xl mb-6">Horario</h2>
            <table class="w-full text-sm font-body" aria-label="Horario del bar">
              <tbody>
                {horarios.map((h: any, i: number) => (
                  <tr class={i < horarios.length - 1 ? 'border-b border-ink/5' : ''}>
                    <td class="py-2 font-semibold text-ink uppercase text-[0.7rem]">{h.dia}</td>
                    <td class="py-2 text-right text-ink-faded">{h.turnos.map((t: string[]) => `${t[0]} – ${t[1]}`).join(' / ')}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

        </div>

        <!-- Mapa (Columna Derecha) -->
        <div class="fade-in">
          <h2 class="font-display text-2xl mb-6 border-b border-ink/10 pb-2">En el mapa</h2>
          <div class="border-2 border-double border-ink/10 p-1 bg-paper-white shadow-lg">
            <iframe
              src="https://maps.google.com/maps?q=Bar+Estanco,+R%C3%BAa+San+Bieito+1,+Gondomar,+Pontevedra&hl=es&z=17&output=embed"
              width="100%"
              height="450"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Bar Estanco en Google Maps"
              class="w-full"
            ></iframe>
          </div>
          <div class="mt-4 flex justify-end">
            <a 
              href="https://maps.google.com/?q=Bar+Estanco+Gondomar"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary text-xs"
            >
              Ver en Google Maps &rarr;
            </a>
          </div>
        </div>

      </div>

      <!-- FRASE MÍTICA (Mantenida y centrada) -->
      <div class="mt-20 pt-12 border-t border-ink/10 text-center">
        <p class="handwritten text-2xl sm:text-3xl text-wine italic">
          &ldquo;En la barra más antigua de Gondomar. Pásate cuando quieras.&rdquo;
        </p>
      </div>
    </div>
  </section>


  <!-- CTA FINAL -->
  <section class="section-wine py-12 sm:py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto fade-in">
      <h2 class="text-paper text-2xl sm:text-3xl mb-6">¿Vienes a vernos?</h2>
      <a href="tel:+34986360098" class="btn-primary bg-paper text-ink border-paper hover:bg-transparent hover:!text-paper px-10">
        Llamar ahora: 986 360 098
      </a>
    </div>
  </section>

</BaseLayout>
