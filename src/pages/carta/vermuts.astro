---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Divider from '../../components/ui/Divider.astro';
import WineEntry from '../../components/ui/WineEntry.astro';
import carta from '../../data/carta.json';

const vermuts = carta.vermuts;
const totalVermuts = vermuts.reduce((sum, g) => sum + g.items.length, 0);
---

<BaseLayout
  title="Vermuts en Gondomar — Carta de Vermuts"
  description="Carta de vermuts de Bar Estanco en Gondomar. Martini, Padró, Petroni, Yzaguirre, Povarelo y más. Vermut artesanal y spritz de naranja con cava. Vinoteca y tapería en Gondomar."
>

  <!-- Header -->
  <section class="section-ink py-10 sm:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label border-paper/20 text-paper/50 mb-4">Capítulo II</span>
      <h1 class="text-paper mt-4 mb-3">Vermuts</h1>
      <p class="text-paper-dark/70 max-w-lg mx-auto font-body text-sm sm:text-base">
        Selección cuidada para el aperitivo. Desde el clásico
        hasta el artesanal gallego.
      </p>
    </div>
  </section>


  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <section class="py-8 sm:py-(--spacing-section)">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">La Hora del Vermut</span>
        <h2 class="mt-4">Nuestra selección</h2>
        <p class="text-ink-faded text-sm mt-2 font-body">{totalVermuts} referencias</p>
        <Divider />
      </div>

      {vermuts.map((grupo, i) => (
        <div class:list={['fade-in', i < vermuts.length - 1 ? 'mb-8' : 'mb-8']}>
          <h3 class="do-header">{grupo.do}</h3>
          <div class="space-y-0">
            {grupo.items.map((v) => (
              <WineEntry
                nombre={v.nombre}
                bodega={v.bodega}
                tipo={v.tipo}
                precio={v.precio}
                precioCopa={v.precioCopa}
                destacado={v.destacado}
                descripcion={v.descripcion}
              />
            ))}
          </div>
        </div>
      ))}

      <!-- Nota manuscrita -->
      <div class="text-center fade-in mt-6">
        <p class="handwritten text-lg sm:text-xl">
          &ldquo;El vermut se toma sin prisa. Es un ritual, no una bebida.&rdquo;
        </p>
      </div>
    </section>

  </div>


  <!-- CTA -->
  <section class="section-wine py-10 sm:py-16 px-4 mt-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/carta" class="btn-secondary border-paper/30 text-paper/80 hover:bg-paper/10 hover:border-paper/50">
          &larr; Volver a la carta
        </a>
        <a href="/carta/vinos" class="btn-secondary border-paper/30 text-paper/80 hover:bg-paper/10 hover:border-paper/50">
          Ver vinos
        </a>
        <a href="/carta/tapas" class="btn-primary border-paper/40 bg-paper text-ink hover:bg-transparent hover:text-paper">
          Ver tapas &rarr;
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
