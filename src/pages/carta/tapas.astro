---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Divider from '../../components/ui/Divider.astro';
import WineEntry from '../../components/ui/WineEntry.astro';
import AllergenIcon from '../../components/ui/AllergenIcon.astro';
import CartaNav from '../../components/ui/CartaNav.astro';
import CartaFooterNav from '../../components/ui/CartaFooterNav.astro';
import { getCarta } from '../../lib/kv';

const carta = await getCarta();
const tapas = carta.tapas;
const conservas = carta.conservas;
const totalTapas = tapas.reduce((sum, g) => sum + g.items.length, 0);
const totalConservas = conservas.reduce((sum, g) => sum + g.items.length, 0);
---

<BaseLayout
  title="Raciones en Gondomar — Tapería Bar Estanco"
  description="Raciones y tapas en Gondomar: callos, empanada, lacón con grelos, tablas de quesos y embutidos, patés de La Curiosa, conservas artesanas y más. Bar Estanco, vinoteca y tapería desde 1938."
>

  <!-- Header -->
  <section class="section-ink py-10 sm:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label border-paper/20 text-paper/50 mb-4">Capítulos III y IV</span>
      <h1 class="text-paper mt-4 mb-3">Raciones, Patés y Conservas</h1>
      <p class="text-paper-dark/70 max-w-lg mx-auto font-body text-sm sm:text-base">
        Producto gallego de calidad. Todo para acompañar un buen vino.
      </p>
    </div>
  </section>

  <!-- Nav entre cartas -->
  <CartaNav current="tapas" />

  <!-- Sticky nav -->
  <div class="lg:h-[45px]">
    <nav class="carta-nav-sticky">
      <div class="max-w-4xl mx-auto px-4 flex items-center gap-1 py-2 overflow-x-auto">
        <a href="#tapas" class="carta-nav-link">Raciones</a>
        <span class="text-ink/15 text-xs">&middot;</span>
        <a href="#conservas" class="carta-nav-link">Patés y conservas</a>
      </div>
    </nav>
  </div>


  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ============================== -->
    <!--      TAPAS Y RACIONES          -->
    <!-- ============================== -->
    <section id="tapas" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Raciones</span>
        <h2 class="mt-4">Raciones y Tablas</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">{totalTapas} referencias</p>
        <Divider />
      </div>

      {tapas.map((grupo, i) => (
        <div class:list={['fade-in', i < tapas.length - 1 ? 'mb-8' : 'mb-4']}>
          <h3 class="do-header">{grupo.do}</h3>
          <div class="space-y-0">
            {grupo.items.map((v) => (
              v.precioMedia ? (
                <div class="wine-entry">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center flex-wrap gap-x-2 gap-y-1">
                      <span class="wine-entry-name">{v.nombre}</span>
                      {v.alergenos && v.alergenos.length > 0 && (
                        <div class="flex items-center gap-1 ml-1 relative -top-[1px]">
                          {v.alergenos.map((a: string) => <AllergenIcon name={a} />)}
                        </div>
                      )}
                    </div>
                    {v.tipo && <span class="wine-entry-detail">{v.tipo}</span>}
                  </div>
                  <div class="text-right">
                    <span class="wine-entry-price">{v.precio} &euro;</span>
                    <span class="block text-[0.65rem] text-ink-faded">media {v.precioMedia} &euro;</span>
                  </div>
                </div>
              ) : (
                <WineEntry
                  nombre={v.nombre}
                  bodega={v.bodega}
                  tipo={v.tipo}
                  precio={v.precio}
                  precioCopa={v.precioCopa}
                  destacado={v.destacado}
                  descripcion={v.descripcion}
                  alergenos={v.alergenos}
                />
              )
            ))}
          </div>
        </div>
      ))}
    </section>


    <Divider />


    <!-- ============================== -->
    <!--    PATÉS Y CONSERVAS           -->
    <!-- ============================== -->
    <section id="conservas" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Patés y Conservas</span>
        <h2 class="mt-4">Patés y Conservas</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">{totalConservas} referencias</p>
        <Divider />
      </div>

      {conservas.map((grupo, i) => (
        <div class:list={['fade-in', i < conservas.length - 1 ? 'mb-8' : 'mb-4']}>
          <h3 class="do-header">{grupo.do}</h3>
          <div class="space-y-0">
            {grupo.items.map((v) => (
              <WineEntry
                nombre={v.nombre}
                bodega={v.bodega}
                tipo={v.tipo}
                precio={v.precio}
                destacado={v.destacado}
                descripcion={v.descripcion}
              />
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Nota manuscrita -->
    <div class="text-center fade-in mt-6 mb-12">
      <p class="handwritten text-xl sm:text-2xl">
        &ldquo;El pincho del día va incluido con cada consumición.&rdquo;
      </p>
    </div>

    <!-- Leyenda de alérgenos -->
    <div class="max-w-2xl mx-auto border-t border-ink/10 pt-8 pb-16 fade-in text-center">
      <p class="font-display text-[0.65rem] uppercase tracking-[0.2em] text-ink/40 mb-4">Información sobre alérgenos</p>
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3">
        {[
          'Gluten', 'Lácteos', 'Crustáceos', 'Moluscos'
        ].map(a => (
          <div class="flex items-center gap-2">
            <AllergenIcon name={a} />
            <span class="text-[0.65rem] uppercase tracking-wider text-ink/60 font-body">{a}</span>
          </div>
        ))}
      </div>
    </div>

  </div>

  <CartaFooterNav current="tapas" />

</BaseLayout>
