---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Divider from '../../components/ui/Divider.astro';
import WineEntry from '../../components/ui/WineEntry.astro';
---

<BaseLayout
  title="Tapas en Gondomar — Tapería Bar Estanco"
  description="Tapería en Gondomar: tapas gallegas, tablas de quesos y embutidos, patés de La Curiosa, conservas artesanas de Paco Lafuente y más. Bar Estanco, vinoteca y tapería desde 1938."
>

  <!-- Header -->
  <section class="section-ink py-10 sm:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label border-paper/20 text-paper/50 mb-4">Capítulos III y IV</span>
      <h1 class="text-paper mt-4 mb-3">Tapas, Patés y Conservas</h1>
      <p class="text-paper-dark/70 max-w-lg mx-auto font-body text-sm sm:text-base">
        Producto gallego de verdad. Todo para acompañar un buen vino.
      </p>
    </div>
  </section>

  <!-- Sticky nav -->
  <nav class="carta-nav-sticky">
    <div class="max-w-4xl mx-auto px-4 flex items-center gap-2 py-2">
      <a href="#tapas" class="carta-nav-link">Tapas</a>
      <span class="text-ink/15 text-xs">&middot;</span>
      <a href="#conservas" class="carta-nav-link">Patés y conservas</a>
    </div>
  </nav>


  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ============================== -->
    <!--      TAPAS Y RACIONES          -->
    <!-- ============================== -->
    <section id="tapas" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Tapas</span>
        <h2 class="mt-4">Tapas, Tablas y Raciones</h2>
        <p class="text-ink-faded text-sm mt-2 font-body">8 referencias</p>
        <Divider />
      </div>

      <!-- Tapas -->
      <div class="mb-8 fade-in">
        <h3 class="do-header">Tapas</h3>
        <div class="space-y-0">
          <WineEntry nombre="Ensaladilla" tipo="Receta de la casa" precio="7.50" />
          <WineEntry nombre="Tortilla" tipo="Española, jugosa por dentro" precio="12" destacado descripcion="Tortilla española como manda la tradición. Jugosa por dentro y dorada por fuera." />
          <WineEntry nombre="Ensalada de tomate con ventresca" tipo="Tomate de temporada" precio="14.50" />
        </div>
      </div>

      <!-- Tablas -->
      <div class="mb-8 fade-in">
        <h3 class="do-header">Tablas</h3>
        <div class="space-y-0">
          <div class="wine-entry">
            <div class="flex-1 min-w-0">
              <span class="wine-entry-name">Tabla de quesos</span>
              <span class="wine-entry-detail">Gallegos y nacionales</span>
            </div>
            <div class="text-right">
              <span class="wine-entry-price">16 &euro;</span>
              <span class="block text-[0.65rem] text-ink-faded">media 8 &euro;</span>
            </div>
          </div>
          <div class="wine-entry">
            <div class="flex-1 min-w-0">
              <span class="wine-entry-name">Tabla de embutidos</span>
              <span class="wine-entry-detail">Cortados al momento</span>
            </div>
            <div class="text-right">
              <span class="wine-entry-price">18 &euro;</span>
              <span class="block text-[0.65rem] text-ink-faded">media 9 &euro;</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Raciones -->
      <div class="mb-4 fade-in">
        <h3 class="do-header">Raciones</h3>
        <div class="space-y-0">
          <WineEntry nombre="Lacón á feira" tipo="Con pimentón y aceite de oliva" precio="12" destacado descripcion="Lacón cocido con pimentón cachena y aceite de oliva. Galicia en un plato." />
          <WineEntry nombre="Jamón ibérico de cebo" tipo="Cortado a mano" precio="18" />
          <WineEntry nombre="Tostas de jamón ibérico con tomate" tipo="Ibérico de cebo + tomate rallado" precio="20" />
        </div>
      </div>
    </section>


    <Divider label="&middot; &middot; &middot;" />


    <!-- ============================== -->
    <!--    PATÉS Y CONSERVAS           -->
    <!-- ============================== -->
    <section id="conservas" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Patés y Conservas</span>
        <h2 class="mt-4">Patés y Conservas</h2>
        <p class="text-ink-faded text-sm mt-2 font-body">18 referencias</p>
        <Divider />
      </div>

      <!-- Patés La Curiosa -->
      <div class="mb-8 fade-in">
        <h3 class="do-header">Patés La Curiosa</h3>
        <div class="space-y-0">
          <WineEntry nombre="Paté de Nécora" bodega="La Curiosa" precio="12" destacado descripcion="Paté de nécora con todo el sabor del marisco gallego." />
          <WineEntry nombre="Paté de Pulpo a la Gallega" bodega="La Curiosa" precio="10" />
          <WineEntry nombre="Paté de Bonito con Piquillos" bodega="La Curiosa" precio="10" />
          <WineEntry nombre="Paté de Caballa Picante" bodega="La Curiosa" precio="10" />
          <WineEntry nombre="Paté de Atún Claro con Mostaza y Miel" bodega="La Curiosa" precio="10" />
          <WineEntry nombre="Paté de Centollo y Buey de Mar" bodega="La Curiosa" precio="12" destacado descripcion="Centollo y buey de mar. El paté más premium de la selección." />
          <WineEntry nombre="Paté de Mejillones" bodega="La Curiosa" precio="10" />
        </div>
      </div>

      <!-- Patés Emilia -->
      <div class="mb-8 fade-in">
        <h3 class="do-header">Patés Conservas Emilia</h3>
        <div class="space-y-0">
          <WineEntry nombre="Paté de Anchoa" bodega="Conservas Emilia" precio="9" />
          <WineEntry nombre="Paté de Cabracho" bodega="Conservas Emilia" precio="9" />
        </div>
      </div>

      <!-- Conservas artesanas -->
      <div class="mb-8 fade-in">
        <h3 class="do-header">Conservas Artesanas</h3>
        <div class="space-y-0">
          <WineEntry nombre="Sardinas en Aceite de Oliva Trufado" tipo="Con aceite trufado" precio="12" />
          <WineEntry nombre="Atún al Pesto" tipo="Fusión mediterránea" precio="12" />
          <WineEntry nombre="Sardinas con Pimiento de Padrón" tipo="Dos clásicos gallegos" precio="12" />
          <WineEntry nombre="Atún al Curry" tipo="Con toque de curry" precio="12" />
        </div>
      </div>

      <!-- Ramón Franco -->
      <div class="mb-8 fade-in">
        <h3 class="do-header">Conservas Ramón Franco</h3>
        <div class="space-y-0">
          <WineEntry nombre="Sardinas" bodega="Ramón Franco" precio="10" />
          <WineEntry nombre="Mejillones en escabeche" bodega="Ramón Franco" precio="10" />
        </div>
      </div>

      <!-- Paco Lafuente -->
      <div class="mb-4 fade-in">
        <h3 class="do-header">Paco Lafuente &middot; Premium</h3>
        <div class="space-y-0">
          <WineEntry nombre="Mejillones Fritos" bodega="Paco Lafuente" precio="10" />
          <WineEntry nombre="Sardinillas" bodega="Paco Lafuente" precio="12" destacado descripcion="Sardinillas en aceite de oliva. Paco Lafuente es garantía de calidad." />
          <WineEntry nombre="Zamburiñas" bodega="Paco Lafuente" precio="12" destacado descripcion="Zamburiñas gallegas en conserva premium." />
        </div>
      </div>
    </section>

  </div>


  <!-- CTA -->
  <section class="section-wine py-10 sm:py-16 px-4 mt-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <p class="font-hand text-paper/90 text-lg sm:text-xl mb-6" style="transform: rotate(-1deg);">
        &ldquo;El pincho del día va incluido con cada consumición.&rdquo;
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/carta" class="btn-secondary border-paper/30 text-paper/80 hover:bg-paper/10 hover:border-paper/50">
          &larr; Volver a la carta
        </a>
        <a href="/carta/vinos" class="btn-primary border-paper/40 bg-paper text-ink hover:bg-transparent hover:text-paper">
          Ver vinos
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
