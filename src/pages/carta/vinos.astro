---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Divider from "../../components/ui/Divider.astro";
import WineEntry from "../../components/ui/WineEntry.astro";
import CartaNav from "../../components/ui/CartaNav.astro";
import CartaFooterNav from "../../components/ui/CartaFooterNav.astro";
import { getCarta } from "../../lib/kv";

const carta = await getCarta();
const { tintos, blancos, rosados, espumosos, sinAlcohol } = carta.vinos;
const copaItems: { nombre: string; precio: string }[] = (carta.copa?.[0]?.items ?? []).filter((i: any) => i.nombre?.trim());

const totalTintos = tintos.reduce((sum, g) => sum + g.items.length, 0);
const totalBlancos = blancos.reduce((sum, g) => sum + g.items.length, 0);
const totalRosados = rosados.reduce((sum, g) => sum + g.items.length, 0);
const totalEspumosos = espumosos.reduce((sum, g) => sum + g.items.length, 0);
const totalSinAlcohol = sinAlcohol.reduce((sum, g) => sum + g.items.length, 0);
---

<BaseLayout
  title="Carta de Vinos en Gondomar — Más de 70 referencias"
  description="Carta de vinos de Bar Estanco, vinoteca en Gondomar. Más de 70 referencias: Albariño, Godello, Ribera del Duero, Rioja, Mencía, vinos internacionales, espumosos y sin alcohol."
>
  <!-- Header -->
  <section class="section-ink py-10 sm:py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label border-paper/20 text-paper/50 mb-4"
        >Capítulo I</span
      >
      <h1 class="text-paper mt-4 mb-3">Carta de Vinos</h1>
      <p
        class="text-paper-dark/70 max-w-lg mx-auto font-body text-sm sm:text-base"
      >
        Más de 70 referencias elegidas con criterio. Pregunta en barra, te
        ayudamos a elegir.
      </p>
    </div>
  </section>

  <!-- Nav entre cartas -->
  <CartaNav current="vinos" />

  <!-- Wrapper que da altura al containing block del sticky nav -->
  <div class="relative">
    <nav class="carta-nav-sticky">
      <div class="max-w-4xl mx-auto px-4 flex items-center gap-1 py-2 overflow-x-auto">
        <a href="#tintos" class="carta-nav-link">Tintos</a>
        <span class="text-ink/15 text-xs">&middot;</span>
        <a href="#blancos" class="carta-nav-link">Blancos</a>
        <span class="text-ink/15 text-xs">&middot;</span>
        <a href="#rosados" class="carta-nav-link">Rosados</a>
        <span class="text-ink/15 text-xs">&middot;</span>
        <a href="#espumosos" class="carta-nav-link">Espumosos</a>
        <span class="text-ink/15 text-xs">&middot;</span>
        <a href="#sin-alcohol" class="carta-nav-link">Sin alcohol</a>
      </div>
    </nav>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Selección por Copa (Highlighted Section) -->
    <section class="mt-8 sm:mt-12 mb-4 fade-in">
      <div
        class="bg-paper-white border-2 border-wine/10 p-6 sm:p-10 shadow-lg relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-32 h-32 bg-wine/5 rounded-full -mr-16 -mt-16"
        >
        </div>

        <div class="relative z-10">
          <span
            class="text-wine font-display text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-2 block"
            >Sugerencia del Tabernero</span
          >
          <h2 class="text-2xl sm:text-3xl mb-4 tracking-tight">
            Selección por Copa
          </h2>
          <p
            class="text-ink-faded text-base font-body mb-8 leading-relaxed max-w-2xl"
          >
            No hace falta abrir la botella entera para disfrutar de una joya. <br
              class="hidden sm:block"
            />
            Muchos de nuestros vinos están disponibles por copa para que puedas viajar
            por diferentes bodegas en una sola visita.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-2">
            {copaItems.map((item) => (
              <div class="flex items-center justify-between py-2 border-b border-wine/5">
                <span class="font-display text-sm font-semibold text-ink">{item.nombre}</span>
                <span class="copa-badge">{item.precio.replace('.', ',')} &euro;</span>
              </div>
            ))}
            {copaItems.length === 0 && (
              <p class="text-ink-faded text-sm font-body col-span-2 py-2">Pregunta en barra por nuestra selección del día.</p>
            )}
          </div>

          <div class="mt-8 flex items-center gap-2">
            <svg
              class="w-4 h-4 text-wine/40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
            <p
              class="text-[0.7rem] text-ink-faded italic font-body uppercase tracking-tighter"
            >
              Busca el distintivo de copa en toda la carta para descubrir más
              opciones
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- TINTOS -->
    <section id="tintos" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Tintos</span>
        <h2 class="mt-4">Vinos Tintos</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">
          {totalTintos} referencias
        </p>
        <Divider />
      </div>

      {
        tintos.map((grupo, i) => (
          <div
            class:list={["fade-in", i < tintos.length - 1 ? "mb-8" : "mb-4"]}
          >
            <h3 class="do-header">{grupo.do}</h3>
            <div class="space-y-0">
              {grupo.items.map((v) => (
                <WineEntry
                  nombre={v.nombre}
                  bodega={v.bodega}
                  tipo={v.tipo}
                  precio={v.precio}
                  precioCopa={v.precioCopa}
                  destacado={v.destacado}
                  descripcion={v.descripcion}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <Divider />

    <!-- BLANCOS -->
    <section id="blancos" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Blancos</span>
        <h2 class="mt-4">Vinos Blancos</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">
          {totalBlancos} referencias
        </p>
        <Divider />
      </div>

      {
        blancos.map((grupo, i) => (
          <div
            class:list={["fade-in", i < blancos.length - 1 ? "mb-8" : "mb-4"]}
          >
            <h3 class="do-header">{grupo.do}</h3>
            <div class="space-y-0">
              {grupo.items.map((v) => (
                <WineEntry
                  nombre={v.nombre}
                  bodega={v.bodega}
                  tipo={v.tipo}
                  precio={v.precio}
                  precioCopa={v.precioCopa}
                  destacado={v.destacado}
                  descripcion={v.descripcion}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <Divider />

    <!-- ROSADOS -->
    <section id="rosados" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Rosados</span>
        <h2 class="mt-4">Vinos Rosados</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">
          {totalRosados} referencias
        </p>
        <Divider />
      </div>

      {
        rosados.map((grupo) => (
          <div class="fade-in">
            <div class="space-y-0">
              {grupo.items.map((v) => (
                <WineEntry
                  nombre={v.nombre}
                  bodega={v.bodega}
                  tipo={v.tipo}
                  precio={v.precio}
                  precioCopa={v.precioCopa}
                  destacado={v.destacado}
                  descripcion={v.descripcion}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <Divider />

    <!-- ESPUMOSOS -->
    <section id="espumosos" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Espumosos</span>
        <h2 class="mt-4">Espumosos y Cavas</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">
          {totalEspumosos} referencias
        </p>
        <Divider />
      </div>

      {
        espumosos.map((grupo, i) => (
          <div
            class:list={["fade-in", i < espumosos.length - 1 ? "mb-8" : "mb-4"]}
          >
            <h3 class="do-header">{grupo.do}</h3>
            <div class="space-y-0">
              {grupo.items.map((v) => (
                <WineEntry
                  nombre={v.nombre}
                  bodega={v.bodega}
                  tipo={v.tipo}
                  precio={v.precio}
                  precioCopa={v.precioCopa}
                  destacado={v.destacado}
                  descripcion={v.descripcion}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <Divider />

    <!-- SIN ALCOHOL -->
    <section id="sin-alcohol" class="pt-8 sm:pt-(--spacing-section) pb-6">
      <div class="text-center mb-8 fade-in">
        <span class="section-label mb-4">Sin Alcohol</span>
        <h2 class="mt-4">Vinos Sin Alcohol</h2>
        <p class="text-ink-faded text-sm mt-2 font-body text-center mx-auto">
          {totalSinAlcohol} referencias
        </p>
        <Divider />
      </div>

      {
        sinAlcohol.map((grupo) => (
          <div class="fade-in">
            <div class="space-y-0">
              {grupo.items.map((v) => (
                <WineEntry
                  nombre={v.nombre}
                  bodega={v.bodega}
                  tipo={v.tipo}
                  precio={v.precio}
                  precioCopa={v.precioCopa}
                  destacado={v.destacado}
                  descripcion={v.descripcion}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <!-- Nota manuscrita -->
    <div class="text-center fade-in mt-6 mb-2">
      <p class="handwritten text-xl sm:text-2xl">
        &ldquo;Si no lo ves en la carta, pregunta. Siempre hay algo
        nuevo.&rdquo;
      </p>
    </div>
  </div>
  </div>{/* cierre del wrapper sticky containing block */}

  <CartaFooterNav current="vinos" />
</BaseLayout>
