---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge1938 from "../components/ui/Badge1938.astro";
import Divider from "../components/ui/Divider.astro";
import ReviewCard from "../components/ui/ReviewCard.astro";
import { Image } from "astro:assets";
import { getHorarios } from "../lib/kv";

const horarios = await getHorarios();
---

<BaseLayout
  title="Vinoteca y Tapería en Gondomar desde 1938"
  description="Vinoteca y tapería en Gondomar desde 1938. Más de 70 vinos, vermuts, tapas gallegas y conservas premium. Cuatro generaciones de historia en el Bar Estanco."
>
  <!-- ============ SPLASH SCREEN (solo primera visita) ============ -->
  <div class="splash-overlay" id="splash" aria-hidden="true">
    <div class="splash-stamp">
      <div>
        <span class="splash-stamp-text">Desde</span>
        <span class="splash-stamp-year">1938</span>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const splash = document.getElementById("splash");
      if (!splash) return;
      if (sessionStorage.getItem("splash-seen")) {
        splash.style.display = "none";
        splash.remove();
      } else {
        sessionStorage.setItem("splash-seen", "1");
      }
    })();
  </script>

  <!-- ============ HERO CLEAN & PREMIUM ============ -->
  <section
    class="relative min-h-[80vh] sm:min-h-[90vh] flex items-center justify-center overflow-hidden section-ink"
  >
    <Image
      id="hero-img"
      src="/images/historicas/Estanco-1900.jpg"
      alt="Bar Estanco a principios de siglo"
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover photo-vintage opacity-40"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-ink/40"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <!-- Sello minimalista superior -->
      <div class="fade-in mb-4 opacity-80">
        <span
          class="text-paper/60 font-display text-xs tracking-[0.4em] uppercase"
          >Gondomar · Est. 1938</span
        >
      </div>

      <h1
        class="fade-in text-paper font-display font-bold mb-6 leading-[0.9] tracking-tighter text-6xl sm:text-8xl md:text-9xl drop-shadow-2xl"
      >
        Bar Estanco
      </h1>

      <p
        class="fade-in font-display text-paper-dark/90 text-lg sm:text-2xl md:text-3xl font-light italic mb-12"
      >
        Vinoteca y tapería de toda la vida
      </p>

      <div
        class="fade-in flex flex-col sm:flex-row items-center justify-center gap-6"
      >
        <a
          href="/carta"
          class="btn-primary border-paper bg-paper text-ink hover:bg-transparent hover:text-paper px-12 py-4 text-base shadow-2xl"
        >
          Ver nuestra carta
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center px-8 py-4 min-h-[44px] text-paper/85 font-body font-bold text-sm tracking-[0.12em] uppercase border-2 border-paper/40 bg-transparent transition-all duration-300 hover:bg-paper/10 hover:border-paper/70 hover:text-paper active:scale-[0.97]"
        >
          Ubicación
        </a>
      </div>
    </div>

    <div
      class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-30"
      aria-hidden="true"
    >
      <div class="w-[1px] h-16 bg-gradient-to-b from-paper to-transparent">
      </div>
    </div>
  </section>

  <!-- ============ FRASE MÍTICA ============ -->
  <section class="py-12 bg-paper relative z-20 texture-paper">
    <div class="max-w-3xl mx-auto text-center px-4">
      <p
        class="handwritten text-2xl sm:text-4xl text-wine opacity-90 leading-tight"
      >
        &ldquo;Sin renunciar al pasado,<br class="sm:hidden" /> pero mirando al futuro&rdquo;
      </p>
    </div>
  </section>

  <!-- ============ CRÓNICA LOCAL ============ -->
  <section class="py-16 sm:py-24 px-4 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="asymmetric-grid">
        <div class="fade-in">
          <span class="section-label-alt">Crónica Local</span>
          <h2 class="mb-8 leading-tight">
            Un bar de verdad,<br />donde el tiempo se para.
          </h2>

          <div id="cronica-section">
            <p
              class="drop-cap text-ink leading-[1.8] text-base sm:text-xl mb-6 cronica-p"
            >
              En la plaza de San Bieito, en el centro de Gondomar, hay un bar
              que lleva abierto desde la guerra. Cuatro generaciones de la misma
              familia han servido vino detrás de la misma barra. No es un bar de
              moda. Es un bar de verdad, de los que ya casi no quedan.
            </p>
            <p
              class="text-ink-faded leading-[1.8] text-base sm:text-xl mb-8 cronica-p"
            >
              Más de 70 referencias de vino. Albariños, Godellos, Riberas,
              Riojas y una selección que va de Chile a Francia. Vermuts con
              carácter. Conservas de las buenas. Y un pincho de la casa cada
              día, porque aquí se viene a disfrutar.
            </p>
          </div>

          <div class="flex items-center gap-4 mt-8">
            <div class="h-[1px] flex-1 bg-ink/10"></div>
            <p class="handwritten text-2xl text-ink">
              &ldquo;Desde 1938&rdquo;
            </p>
          </div>
        </div>

        <div class="fade-in relative mt-12 md:mt-0">
          <!-- Imagen panorámica de la fachada actual del bar -->
          <div class="relative overflow-hidden shadow-2xl" style="transform: rotate(-1deg);">
            <Image
              src="/images/estanco-actual.webp"
              alt="Fachada actual del Bar Estanco en la plaza de San Bieito, Gondomar"
              width={1200}
              height={675}
              class="w-full h-auto photo-vintage object-cover"
              loading="lazy"
              decoding="async"
            />
            <!-- Velo sutil para integrar con el fondo editorial -->
            <div class="absolute inset-0 bg-gradient-to-t from-ink/20 to-transparent pointer-events-none"></div>
          </div>
          <!-- Medallón "Desde 1938" anclado a la esquina -->
          <div
            class="absolute -bottom-5 -right-4 w-28 h-28 border-2 border-wine/30 rounded-full flex items-center justify-center bg-paper p-3 rotate-6 hidden sm:flex shadow-lg"
          >
            <span
              class="text-[0.6rem] font-display font-bold text-wine text-center leading-tight uppercase tracking-tighter"
              >Desde<br />1938</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MANIFIESTO DEL BODEGUERO ============ -->
  <section class="section-dark py-16 sm:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <div
        class="border-y border-ink/20 py-16 px-4 sm:px-12 text-center fade-in relative"
      >
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-ink px-6">
          <span
            class="font-display text-xs tracking-[0.2em] uppercase text-paper/80"
            >Nota de la familia</span
          >
        </div>

        <p
          class="font-display text-2xl sm:text-3xl md:text-4xl text-ink leading-[1.6] mb-10 font-light max-w-3xl mx-auto"
        >
          &ldquo;Un bar de verdad donde se sirve buen vino y te sientes como en casa.&rdquo;
        </p>

        <div class="flex items-center justify-center gap-6 opacity-80">
          <div class="w-16 h-[1px] bg-wine/30"></div>
          <span class="font-hand text-2xl sm:text-3xl text-ink rotate-[-2deg]"
            >Cuatro generaciones</span
          >
          <div class="w-16 h-[1px] bg-wine/30"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CARTA DESTACADA ============ -->
  <section class="py-16 sm:py-24 px-4 bg-paper-white texture-paper">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <span class="section-label-alt">Selección de la Casa</span>
        <h2 class="mt-4">Nuestras Cartas</h2>
        <p class="mt-3 text-ink-faded max-w-lg mx-auto font-body text-base">
          Producto gallego de calidad y una bodega que invita a descubrir.
        </p>
        <Divider />
      </div>

      <div class="flex flex-wrap justify-center gap-6 stagger-fade">
        <a
          href="/carta/vinos"
          class="card-lift group p-5 sm:p-6 border-2 border-double border-ink/10 hover:border-wine/30 transition-all duration-300 active:bg-wine/5 flex-[1_1_150px] max-w-[220px] flex flex-col items-center text-center"
        >
          <h3
            class="font-display text-base sm:text-lg text-ink group-hover:text-wine transition-colors mb-1 sm:mb-2"
          >
            Vinos
          </h3>
          <div class="my-3 w-full flex items-center gap-2">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent to-ink/12"></div>
            <span class="w-[5px] h-[5px] rotate-45 border border-wine/40 flex-shrink-0"></span>
            <div class="flex-1 h-px bg-gradient-to-l from-transparent to-ink/12"></div>
          </div>
          <p class="text-xs sm:text-sm text-ink-faded">+70 referencias</p>
          <span
            class="inline-block mt-3 text-[0.65rem] font-display font-bold text-wine tracking-[0.12em] uppercase"
          >
            Ver &rarr;
          </span>
        </a>

        <a
          href="/carta/vermuts"
          class="card-lift group p-5 sm:p-6 border-2 border-double border-ink/10 hover:border-wine/30 transition-all duration-300 active:bg-wine/5 flex-[1_1_150px] max-w-[220px] flex flex-col items-center text-center"
        >
          <h3
            class="font-display text-base sm:text-lg text-ink group-hover:text-wine transition-colors mb-1 sm:mb-2"
          >
            Vermuts
          </h3>
          <div class="my-3 w-full flex items-center gap-2">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent to-ink/12"></div>
            <span class="w-[5px] h-[5px] rotate-45 border border-wine/40 flex-shrink-0"></span>
            <div class="flex-1 h-px bg-gradient-to-l from-transparent to-ink/12"></div>
          </div>
          <p class="text-xs sm:text-sm text-ink-faded">8 referencias</p>
          <span
            class="inline-block mt-3 text-[0.65rem] font-display font-bold text-wine tracking-[0.12em] uppercase"
          >
            Ver &rarr;
          </span>
        </a>

        <a
          href="/carta/tapas"
          class="card-lift group p-5 sm:p-6 border-2 border-double border-ink/10 hover:border-wine/30 transition-all duration-300 active:bg-wine/5 flex-[1_1_150px] max-w-[220px] flex flex-col items-center text-center"
        >
          <h3
            class="font-display text-base sm:text-lg text-ink group-hover:text-wine transition-colors mb-1 sm:mb-2"
          >
            Tapas
          </h3>
          <div class="my-3 w-full flex items-center gap-2">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent to-ink/12"></div>
            <span class="w-[5px] h-[5px] rotate-45 border border-wine/40 flex-shrink-0"></span>
            <div class="flex-1 h-px bg-gradient-to-l from-transparent to-ink/12"></div>
          </div>
          <p class="text-xs sm:text-sm text-ink-faded">Producto gallego</p>
          <span
            class="inline-block mt-3 text-[0.65rem] font-display font-bold text-wine tracking-[0.12em] uppercase"
          >
            Ver &rarr;
          </span>
        </a>

        <a
          href="/carta/tapas#conservas"
          class="card-lift group p-5 sm:p-6 border-2 border-double border-ink/10 hover:border-wine/30 transition-all duration-300 active:bg-wine/5 flex-[1_1_150px] max-w-[220px] flex flex-col items-center text-center"
        >
          <h3
            class="font-display text-base sm:text-lg text-ink group-hover:text-wine transition-colors mb-1 sm:mb-2"
          >
            Conservas
          </h3>
          <div class="my-3 w-full flex items-center gap-2">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent to-ink/12"></div>
            <span class="w-[5px] h-[5px] rotate-45 border border-wine/40 flex-shrink-0"></span>
            <div class="flex-1 h-px bg-gradient-to-l from-transparent to-ink/12"></div>
          </div>
          <p class="text-xs sm:text-sm text-ink-faded">18 referencias</p>
          <span
            class="inline-block mt-3 text-[0.65rem] font-display font-bold text-wine tracking-[0.12em] uppercase"
          >
            Ver &rarr;
          </span>
        </a>

        <a
          href="/carta/desayunos"
          class="card-lift group p-5 sm:p-6 border-2 border-double border-ink/10 hover:border-wine/30 transition-all duration-300 active:bg-wine/5 flex-[1_1_150px] max-w-[220px] flex flex-col items-center text-center"
        >
          <h3
            class="font-display text-base sm:text-lg text-ink group-hover:text-wine transition-colors mb-1 sm:mb-2"
          >
            Desayunos
          </h3>
          <div class="my-3 w-full flex items-center gap-2">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent to-ink/12"></div>
            <span class="w-[5px] h-[5px] rotate-45 border border-wine/40 flex-shrink-0"></span>
            <div class="flex-1 h-px bg-gradient-to-l from-transparent to-ink/12"></div>
          </div>
          <p class="text-xs sm:text-sm text-ink-faded">Hasta las 12:30</p>
          <span
            class="inline-block mt-3 text-[0.65rem] font-display font-bold text-wine tracking-[0.12em] uppercase"
          >
            Ver &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ PRUEBA SOCIAL ============ -->
  <section class="section-dark py-16 sm:py-24 px-4 relative overflow-hidden">
    <!-- Decoración de fondo sutil -->
    <div
      class="absolute top-0 right-0 w-64 h-64 bg-wine/5 rounded-full blur-3xl -mr-32 -mt-32"
    >
    </div>

    <div class="max-w-4xl mx-auto relative z-10">
      <div class="text-center mb-16 fade-in">
        <span class="section-label-alt">Voces de la Plaza</span>
        <h2 class="mt-4">Lo que dicen nuestros clientes</h2>
        <Divider />
      </div>

      <div class="grid grid-cols-1 gap-6 fade-in">
        <ReviewCard
          author="ro ro"
          text="En pleno centro de Gondomar, siempre tiene ambiente. Las tapas son buenísimas y la atención de modo familiar y cercano. Tiene una buena selección de vinos, incluso franceses y argentinos. Todo perfecto."
          rating={5}
          badge="Local Guide · Google"
        />
        <ReviewCard
          author="Ana Huarte Crujeiras"
          text="Fantástico!!! Trato, servicio y tapas de primera."
          rating={5}
          badge="Google"
        />
        <ReviewCard
          author="Neru Oca"
          text="Me encantó y el servicio es un 10."
          rating={5}
          badge="Local Guide · Google"
        />
      </div>
    </div>
  </section>

  <!-- ============ PINCHO DEL DÍA ============ -->
  <section class="section-wine py-16 sm:py-28 px-4 relative overflow-hidden">
    <!-- Grano sutil para esta sección oscura -->
    <div
      class="absolute inset-0 opacity-10 mix-blend-overlay pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\"
      0
      0
      200
      200\"
      xmlns="\"
      http:
      www.w3.org
      2000
      svg\"%3E%3Cfilter"
      id="\"
      n\"%3E%3CfeTurbulence"
      type="\"
      fractalNoise\""
      baseFrequency="\"
      0.65\""
      numOctaves="\"
      3\""
      stitchTiles="\"
      stitch\"
      %3E%3C
      filter%3E%3Crect"
      width="\"
      100%25\""
      height="\"
      100%25\""
      filter="\"
      url(%23n)\""
      opacity="\"
      1\"
      %3E%3C
      svg%3E');""
    >
    </div>

    <div class="max-w-4xl mx-auto text-center relative z-10 fade-in">
      <span class="section-label border-paper/20 text-paper/50 mb-6"
        >Tradición Diaria</span
      >
      <h2 class="text-paper text-3xl sm:text-5xl mt-6 mb-8 tracking-tight">
        El pincho de la casa
      </h2>

      <div
        class="bg-paper/5 border border-paper/10 p-8 sm:p-12 backdrop-blur-sm shadow-2xl"
      >
        <p
          class="text-paper text-lg sm:text-2xl max-w-2xl mx-auto leading-relaxed font-body italic"
        >
          &ldquo;Los domingos, empanada gallega &mdash; la que ganó el premio.
          El resto de la semana, sorpresa: ensaladilla, embutidos, quesos,
          lentejas... Siempre casero, siempre generoso.&rdquo;
        </p>
        <div class="divider-editorial max-w-xs mx-auto my-8">
          <span class="divider-editorial-label text-paper/40">&#9671;</span>
        </div>
        <p
          class="handwritten text-paper/90 text-2xl sm:text-3xl"
          style="transform: rotate(-1deg);"
        >
          Va incluido con cada consumición.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ HORARIO ============ -->
  <section class="py-16 sm:py-24 px-4 bg-paper">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div class="fade-in">
          <span class="section-label-alt">Visítanos</span>
          <h2 class="mb-6">Cuándo abrirnos la puerta</h2>
          <p class="text-ink-faded text-lg mb-8">
            Estamos en la plaza de San Bieito, el corazón de Gondomar. Pásate a
            cualquier hora, siempre hay un hueco en la barra.
          </p>
          <div class="flex flex-col gap-4">
            <a
              href="/contacto"
              class="btn-primary bg-ink text-paper border-ink hover:bg-transparent hover:text-ink self-start"
              >Cómo llegar &rarr;</a
            >
          </div>
        </div>

        <div class="fade-in relative">
          <!-- Ledger Book Style -->
          <div
            class="bg-paper-white border border-ink/20 shadow-xl rotate-1 relative px-6 py-12 sm:p-12"
          >
            <!-- Cuaderno: Agujeros en la parte superior -->
            <div
              class="absolute top-3 left-1/4 w-5 h-5 rounded-full bg-ink/20 shadow-inner shadow-ink/40 border-t border-ink/30"
            >
            </div>
            <div
              class="absolute top-3 left-1/2 -translate-x-1/2 w-5 h-5 rounded-full bg-ink/20 shadow-inner shadow-ink/40 border-t border-ink/30"
            >
            </div>
            <div
              class="absolute top-3 right-1/4 w-5 h-5 rounded-full bg-ink/20 shadow-inner shadow-ink/40 border-t border-ink/30"
            >
            </div>

            <!-- Borde de corte perforado falso en top -->
            <div
              class="absolute top-0 left-0 right-0 h-2 border-b-[3px] border-dotted border-ink/10"
            >
            </div>

            <h3
              class="font-hand text-3xl sm:text-4xl text-ink mb-8 rotate-[-2deg] opacity-90 text-center mt-2"
            >
              Horario del Bar
            </h3>

            <table
              class="w-full text-base sm:text-lg font-hand text-ink/90 border-separate border-spacing-y-2"
              aria-label="Horario del bar"
            >
              <tbody>
                {
                  horarios.map((h: any) => (
                    <tr>
                      <td class="py-2 border-b border-blue-900/10 w-1/3">
                        <span class="capitalize">{h.dia.toLowerCase()}</span>
                      </td>
                      <td
                        class="py-2 border-b border-blue-900/10 text-right leading-tight"
                        set:html={h.turnos
                          .map((t: string[]) => `${t[0]} a ${t[1]}`)
                          .join("<br/>")}
                      />
                    </tr>
                  ))
                }
              </tbody>
            </table>

            <div class="mt-8 text-center rotate-[1deg]">
              <p class="text-xs text-ink/60 font-body italic">
                (Sujeto a cambios en festivos locales)
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section
    class="section-ink py-20 sm:py-32 px-4 text-center overflow-hidden relative"
  >
    <div class="max-w-3xl mx-auto relative z-10 fade-in">
      <h2 class="text-4xl sm:text-6xl mb-6 tracking-tighter">
        Te esperamos en la plaza
      </h2>
      <p
        class="text-paper-dark/70 mb-12 max-w-lg mx-auto font-body text-lg sm:text-xl italic"
      >
        ¡Reserva si no te quieres quedar sin tu trocito de historia!
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          href="tel:+34986360098"
          class="text-paper font-display text-2xl sm:text-3xl hover:text-wine-light transition-colors"
        >
          986 360 098
        </a>
        <div class="hidden sm:block h-8 w-[1px] bg-paper/20"></div>
        <a href="/contacto" class="btn-primary bg-paper text-ink border-paper">
          Ver ubicación
        </a>
      </div>
    </div>
  </section>

  <!-- ============ GSAP ANIMATIONS PARA INDEX ============ -->
  <script is:inline>
    function initIndexAnimations() {
      if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined")
        return;
      gsap.registerPlugin(ScrollTrigger);

      // 1. Hero Parallax sutil sin desenfoque excesivo
      const heroImg = document.getElementById("hero-img");
      if (heroImg) {
        gsap.to(heroImg, {
          yPercent: 15,
          ease: "none",
          scrollTrigger: {
            trigger: heroImg.parentElement,
            start: "top top",
            end: "bottom top",
            scrub: true,
          },
        });
      }

      // 2. Text Reveal en Crónica Local
      const cronicaSection = document.getElementById("cronica-section");
      if (cronicaSection) {
        const paragraphs = cronicaSection.querySelectorAll(".cronica-p");
        gsap.fromTo(
          paragraphs,
          { opacity: 0.15, y: 30 },
          {
            opacity: 1,
            y: 0,
            stagger: 0.3,
            ease: "power2.out",
            scrollTrigger: {
              trigger: cronicaSection,
              start: "top 85%",
              end: "bottom 70%",
              scrub: 1,
            },
          }
        );
      }

      // 3. Efecto Baraja en Cartas
      const cards = gsap.utils.toArray(".card-lift");
      if (cards.length > 0) {
        cards.forEach((card) => card.classList.remove("fade-in"));

        gsap.fromTo(
          cards,
          { opacity: 0, y: 80, rotation: 3, scale: 0.95 },
          {
            opacity: 1,
            y: 0,
            rotation: 0,
            scale: 1,
            duration: 1,
            ease: "back.out(1.2)",
            stagger: 0.1,
            scrollTrigger: {
              trigger: cards[0].parentElement,
              start: "top 85%",
              toggleActions: "play none none none",
            },
          }
        );
      }
    }

    document.addEventListener("DOMContentLoaded", initIndexAnimations);
    document.addEventListener("astro:after-swap", initIndexAnimations);
  </script>
</BaseLayout>
